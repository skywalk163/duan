# codegen.duan - Python code generator for bootstrap compiler
# Uses ANTLR规范语法: 段落 段名 接收 参数：body结束。
#
# Takes AST from parser, produces Python source code
# All identifiers use English to avoid ANTLR keyword conflicts

导入 《duan_ast》。
导入 《token》。

导出 generate, init_generator, get_output。

# =============================================================================
# Generator state
# =============================================================================
# Global state for code generation
段 init_generator：
  定义 state 等于 《字典创建》()。
  《字典设置》(state, "lines", 《列表创建》())。
  《字典设置》(state, "indent", 0)。
  《字典设置》(state, "indent_str", "    ")。
  返回 state。

段 add_line 接收 state, line：
  定义 lines 等于 《字典获取》(state, "lines")。
  定义 indent 等于 《字典获取》(state, "indent")。
  定义 indent_str 等于 《字典获取》(state, "indent_str")。
  定义 line_str 等于 《转字符串》(line)。
  定义 prefix 等于 ""。
  定义 i 等于 0。
  当 i 小于 indent：
    设 prefix 为 prefix 加 indent_str。
    i 加上 1。
  《列表追加》(lines, prefix 加 line_str)。

段 indent_push 接收 state：
  定义 indent 等于 《字典获取》(state, "indent")。
  《字典设置》(state, "indent", indent 加 1)。

段 indent_pop 接收 state：
  定义 indent 等于 《字典获取》(state, "indent")。
  如果 indent 大于 0：
    《字典设置》(state, "indent", indent 减 1)。

段 get_output 接收 state：
  定义 lines 等于 《字典获取》(state, "lines")。
  定义 result 等于 ""。
  定义 i 等于 0。
  当 i 小于 《列表长度》(lines)：
    如果 i 大于 0：
      设 result 为 result 加 "\n"。
    设 result 为 result 加 《列表获取》(lines, i)。
    i 加上 1。
  返回 result。

# =============================================================================
# Builtin function name mapping
# =============================================================================
段 map_builtin 接收 name：
  # Standard library functions mapped to _duan_builtin
  如果 name 等于 "打印"：
    返回 "_duan_builtin.打印"。
  如果 name 等于 "输出"：
    返回 "_duan_builtin.打印"。
  如果 name 等于 "输入" 或 name 等于 "读取"：
    返回 "_duan_builtin.读取"。
  如果 name 等于 "转字符串"：
    返回 "_duan_builtin.转字符串"。
  如果 name 等于 "转整数"：
    返回 "_duan_builtin.转整数"。
  如果 name 等于 "转浮点"：
    返回 "_duan_builtin.转浮点"。
  如果 name 等于 "列表创建" 或 name 等于 "列"：
    返回 "_duan_builtin.列表创建"。
  如果 name 等于 "列表长度"：
    返回 "_duan_builtin.列表长度"。
  如果 name 等于 "列表获取"：
    返回 "_duan_builtin.列表获取"。
  如果 name 等于 "列表追加"：
    返回 "_duan_builtin.列表追加"。
  如果 name 等于 "列表弹出"：
    返回 "_duan_builtin.列表弹出"。
  如果 name 等于 "列表包含"：
    返回 "_duan_builtin.列表包含"。
  如果 name 等于 "字典创建" 或 name 等于 "字典"：
    返回 "_duan_builtin.字典创建"。
  如果 name 等于 "字典设置"：
    返回 "_duan_builtin.字典设置"。
  如果 name 等于 "字典获取"：
    返回 "_duan_builtin.字典获取"。
  如果 name 等于 "字典包含键"：
    返回 "_duan_builtin.字典包含键"。
  如果 name 等于 "字典键列表"：
    返回 "_duan_builtin.字典键列表"。
  如果 name 等于 "字典值列表" 或 name 等于 "字典值"：
    返回 "_duan_builtin.字典值列表"。
  如果 name 等于 "字典项列表" 或 name 等于 "字典项"：
    返回 "_duan_builtin.字典项列表"。
  如果 name 等于 "字典删除"：
    返回 "_duan_builtin.字典删除"。
  如果 name 等于 "字符串长度"：
    返回 "_duan_builtin.字符串长度"。
  如果 name 等于 "字符串获取"：
    返回 "_duan_builtin.字符串获取"。
  如果 name 等于 "截取"：
    返回 "_duan_builtin.截取"。
  如果 name 等于 "分割字符串" 或 name 等于 "分割"：
    返回 "_duan_builtin.分割字符串"。
  如果 name 等于 "连接字符串" 或 name 等于 "连接"：
    返回 "_duan_builtin.连接字符串"。
  如果 name 等于 "替换字符串" 或 name 等于 "替换"：
    返回 "_duan_builtin.替换字符串"。
  如果 name 等于 "去除空白" 或 name 等于 "去空格"：
    返回 "_duan_builtin.去除空白"。
  如果 name 等于 "列表排序" 或 name 等于 "排序"：
    返回 "_duan_builtin.列表排序"。
  如果 name 等于 "列表反转" 或 name 等于 "反转"：
    返回 "_duan_builtin.列表反转"。
  如果 name 等于 "列表创建" 或 name 等于 "列"：
    返回 "_duan_builtin.列表创建"。
  如果 name 等于 "是整数"：
    返回 "_duan_builtin.是整数"。
  如果 name 等于 "是浮点"：
    返回 "_duan_builtin.是浮点"。
  如果 name 等于 "是字符串"：
    返回 "_duan_builtin.是字符串"。
  如果 name 等于 "是列表"：
    返回 "_duan_builtin.是列表"。
  如果 name 等于 "是字典"：
    返回 "_duan_builtin.是字典"。
  如果 name 等于 "是空"：
    返回 "_duan_builtin.是空"。
  如果 name 等于 "随机整数"：
    返回 "_duan_builtin.随机整数"。
  如果 name 等于 "随机浮点"：
    返回 "_duan_builtin.随机浮点"。
  如果 name 等于 "随机选择"：
    返回 "_duan_builtin.随机选择"。
  如果 name 等于 "阶乘"：
    返回 "_duan_builtin.阶乘"。
  如果 name 等于 "平均数"：
    返回 "_duan_builtin.平均数"。
  如果 name 等于 "求和"：
    返回 "_duan_builtin.求和"。
  如果 name 等于 "时间戳"：
    返回 "_duan_builtin.时间戳"。
  如果 name 等于 "格式化时间"：
    返回 "_duan_builtin.格式化时间"。
  如果 name 等于 "读取文件"：
    返回 "_duan_builtin.读取文件"。
  如果 name 等于 "写入文件"：
    返回 "_duan_builtin.写入文件"。
  如果 name 等于 "追加文件"：
    返回 "_duan_builtin.追加文件"。
  如果 name 等于 "文件存在"：
    返回 "_duan_builtin.文件存在"。
  如果 name 等于 "目录存在"：
    返回 "_duan_builtin.目录存在"。
  如果 name 等于 "创建目录"：
    返回 "_duan_builtin.创建目录"。
  如果 name 等于 "圆周率"：
    返回 "_duan_builtin.圆周率"。
  如果 name 等于 "自然常数"：
    返回 "_duan_builtin.自然常数"。
  如果 name 等于 "创建令牌"：
    返回 "创建令牌"。
  如果 name 等于 "_读文件":
    返回 "_duan_builtin._读文件"。
  如果 name 等于 "参数列表":
    返回 "sys.argv"。
  # Default: use Chinese name directly
  返回 name。

# =============================================================================
# Expression code generation
# =============================================================================
段 gen_expr 接收 state, node：
  定义 node_type 等于 《列表获取》(node, 0)。
  # Number: ["number", value]
  如果 node_type 等于 "number"：
    返回 《列表获取》(node, 1)。
  # String: ["string", value]
  如果 node_type 等于 "string"：
    定义 引号 为 "'"。
    定义 原始值 等于 《列表获取》(node, 1)。
    # 转义字符串中的特殊字符
    定义 转义值 为 ""。
    定义 k 等于 0。
    当 k 小于 《字符串长度》(原始值)：
      定义 ch 等于 《字符串获取》(原始值, k)。
      如果 ch 等于 "\\"：
        设 转义值 为 转义值 加 "\\\\"。
      否则 如果 ch 等于 "\n"：
        设 转义值 为 转义值 加 "\\n"。
      否则 如果 ch 等于 "\t"：
        设 转义值 为 转义值 加 "\\t"。
      否则 如果 ch 等于 "'"：
        设 转义值 为 转义值 加 "\\'"。
      否则：
        设 转义值 为 转义值 加 ch。
      k 加上 1。
    返回 引号 加 转义值 加 引号。
  # Template string (f-string): ["template_string", value]
  如果 node_type 等于 "template_string"：
    定义 原始值 等于 《列表获取》(node, 1)。
    # 使用双引号包装 f-string，转义双引号和特殊字符
    定义 转义值 为 ""。
    定义 k 等于 0。
    当 k 小于 《字符串长度》(原始值)：
      定义 ch 等于 《字符串获取》(原始值, k)。
      如果 ch 等于 "\\"：
        设 转义值 为 转义值 加 "\\\\"。
      否则 如果 ch 等于 "\n"：
        设 转义值 为 转义值 加 "\\n"。
      否则 如果 ch 等于 "\t"：
        设 转义值 为 转义值 加 "\\t"。
      否则 如果 ch 等于 '"':
        设 转义值 为 转义值 加 '\\"'。
      否则：
        设 转义值 为 转义值 加 ch。
      k 加上 1。
    返回 'f"' 加 转义值 加 '"'。
  # Boolean: ["boolean", value]
  如果 node_type 等于 "boolean"：
    定义 val 等于 《列表获取》(node, 1)。
    如果 val 等于 "真"：
      返回 "True"。
    返回 "False"。
  # Null: ["null"]
  如果 node_type 等于 "null"：
    返回 "None"。
  # Identifier: ["identifier", name]
  如果 node_type 等于 "identifier"：
    返回 《列表获取》(node, 1)。
  # Function call: ["func_call", name, args]
  如果 node_type 等于 "func_call"：
    定义 name 等于 《列表获取》(node, 1)。
    定义 mapped 等于 《map_builtin》(name)。
    定义 args 等于 《列表获取》(node, 2)。
    定义 result 等于 mapped 加 "("。
    定义 i 等于 0。
    当 i 小于 《列表长度》(args)：
      如果 i 大于 0：
        设 result 为 result 加 ", "。
      定义 arg_node 等于 《列表获取》(args, i)。
      定义 arg_code 等于 《gen_expr》(state, arg_node)。
      设 result 为 result 加 arg_code。
      i 加上 1。
    设 result 为 result 加 ")"。
    返回 result。
  # Binary op: ["binary_op", op, left, right]
  如果 node_type 等于 "binary_op"：
    定义 op 等于 《列表获取》(node, 1)。
    定义 left 等于 《gen_expr》(state, 《列表获取》(node, 2))。
    定义 right 等于 《gen_expr》(state, 《列表获取》(node, 3))。
    定义 py_op 等于 op。
    如果 op 等于 "加" 或 op 等于 "+"：
      设 py_op 为 "+"。
    否则 如果 op 等于 "减" 或 op 等于 "-"：
      设 py_op 为 "-"。
    否则 如果 op 等于 "乘" 或 op 等于 "*"：
      设 py_op 为 "*"。
    否则 如果 op 等于 "除" 或 op 等于 "/"：
      设 py_op 为 "/"。
    否则 如果 op 等于 "模" 或 op 等于 "%"：
      设 py_op 为 "%"。
    否则 如果 op 等于 "幂" 或 op 等于 "^"：
      设 py_op 为 "**"。
    否则 如果 op 等于 "大于"：
      设 py_op 为 ">"。
    否则 如果 op 等于 "小于"：
      设 py_op 为 "<"。
    否则 如果 op 等于 "等于" 或 op 等于 "=="：
      设 py_op 为 "=="。
    否则 如果 op 等于 "不等于"：
      设 py_op 为 "!="。
    否则 如果 op 等于 "大于等于"：
      设 py_op 为 ">="。
    否则 如果 op 等于 "小于等于"：
      设 py_op 为 "<="。
    否则 如果 op 等于 "且" 或 op 等于 "与"：
      设 py_op 为 "and"。
    否则 如果 op 等于 "或"：
      设 py_op 为 "or"。
    返回 "(" 加 left 加 " " 加 py_op 加 " " 加 right 加 ")"。
  # Unary op
  如果 node_type 等于 "unary_op"：
    定义 op 等于 《列表获取》(node, 1)。
    定义 operand 等于 《gen_expr》(state, 《列表获取》(node, 2))。
    如果 op 等于 "非" 或 op 等于 "!"：
      返回 "not " 加 operand。
    返回 op 加 operand。
  # List literal: ["list_literal", elements]
  如果 node_type 等于 "list_literal"：
    定义 elems 等于 《列表获取》(node, 1)。
    定义 result 为 "["。
    定义 i 等于 0。
    当 i 小于 《列表长度》(elems)：
      如果 i 大于 0：
        设 result 为 result 加 ", "。
      定义 elem_code 等于 《gen_expr》(state, 《列表获取》(elems, i))。
      设 result 为 result 加 elem_code。
      i 加上 1。
    返回 result 加 "]"。
  # Dict literal: ["dict_literal", pairs]
  如果 node_type 等于 "dict_literal"：
    定义 pairs 等于 《列表获取》(node, 1)。
    定义 result 为 "{"。
    定义 i 等于 0。
    当 i 小于 《列表长度》(pairs)：
      如果 i 大于 0：
        设 result 为 result 加 ", "。
      定义 pair 等于 《列表获取》(pairs, i)。
      定义 key_code 等于 《gen_expr》(state, 《列表获取》(pair, 0))。
      定义 val_code 等于 《gen_expr》(state, 《列表获取》(pair, 1))。
      设 result 为 result 加 key_code 加 ": " 加 val_code。
      i 加上 1。
    返回 result 加 "}"。
  # Member access: ["member_access", object, prop]
  如果 node_type 等于 "member_access"：
    定义 obj 等于 《gen_expr》(state, 《列表获取》(node, 1))。
    定义 prop 等于 《列表获取》(node, 2)。
    返回 obj 加 "." 加 prop。
  # Default
  返回 "None"。

# =============================================================================
# Statement code generation
# =============================================================================
段 gen_stmt 接收 state, node：
  定义 node_type 等于 《列表获取》(node, 0)。
  # Variable declaration: ["var_decl", name, value]
  如果 node_type 等于 "var_decl"：
    定义 name 等于 《列表获取》(node, 1)。
    定义 value 等于 《gen_expr》(state, 《列表获取》(node, 2))。
    《add_line》(state, name 加 " = " 加 value)。
    返回。
  # Assignment: ["assign", name, value]
  如果 node_type 等于 "assign"：
    定义 name 等于 《列表获取》(node, 1)。
    定义 value 等于 《gen_expr》(state, 《列表获取》(node, 2))。
    《add_line》(state, name 加 " = " 加 value)。
    返回。
  # Compound assignment: ["compound_assign", name, op, value]
  如果 node_type 等于 "compound_assign"：
    定义 name 等于 《列表获取》(node, 1)。
    定义 op 等于 《列表获取》(node, 2)。
    定义 value 等于 《gen_expr》(state, 《列表获取》(node, 3))。
    定义 py_op 等于 "+"。
    如果 op 等于 "加上"：
      设 py_op 为 "+"。
    否则 如果 op 等于 "减去"：
      设 py_op 为 "-"。
    否则 如果 op 等于 "乘以"：
      设 py_op 为 "*"。
    否则 如果 op 等于 "除以"：
      设 py_op 为 "/"。
    否则 如果 op 等于 "模以"：
      设 py_op 为 "%"。
    否则 如果 op 等于 "幂以"：
      设 py_op 为 "**"。
    《add_line》(state, name 加 " " 加 py_op 加 "= " 加 value)。
    返回。
  # Return statement: ["return", value]
  如果 node_type 等于 "return"：
    定义 value 等于 《列表获取》(node, 1)。
    如果 value 等于 空：
      《add_line》(state, "return")。
    否则：
      《add_line》(state, "return " 加 《gen_expr》(state, value))。
    返回。
  # If statement: ["if_stmt", cond, body, elif_branches, else_body]
  如果 node_type 等于 "if_stmt"：
    定义 cond 等于 《gen_expr》(state, 《列表获取》(node, 1))。
    定义 body 等于 《列表获取》(node, 2)。
    定义 elif_branches 等于 《列表获取》(node, 3)。
    定义 else_body 等于 《列表获取》(node, 4)。
    《add_line》(state, "if " 加 cond 加 ":")。
    《indent_push》(state)。
    定义 i 等于 0。
    当 i 小于 《列表长度》(body)：
      《gen_stmt》(state, 《列表获取》(body, i))。
      i 加上 1。
    《indent_pop》(state)。
    # Elif branches
    定义 j 等于 0。
    当 j 小于 《列表长度》(elif_branches)：
      定义 branch 等于 《列表获取》(elif_branches, j)。
      定义 elif_cond 等于 《gen_expr》(state, 《列表获取》(branch, 0))。
      定义 elif_body 等于 《列表获取》(branch, 1)。
      《add_line》(state, "elif " 加 elif_cond 加 ":")。
      《indent_push》(state)。
      定义 k 等于 0。
      当 k 小于 《列表长度》(elif_body)：
        《gen_stmt》(state, 《列表获取》(elif_body, k))。
        k 加上 1。
      《indent_pop》(state)。
      j 加上 1。
    # Else body
    如果 else_body 不等于 空：
      《add_line》(state, "else:")。
      《indent_push》(state)。
      定义 m 等于 0。
      当 m 小于 《列表长度》(else_body)：
        《gen_stmt》(state, 《列表获取》(else_body, m))。
        m 加上 1。
      《indent_pop》(state)。
    返回。
  # While loop: ["while_loop", cond, body]
  如果 node_type 等于 "while_loop"：
    定义 cond 等于 《gen_expr》(state, 《列表获取》(node, 1))。
    定义 body 等于 《列表获取》(node, 2)。
    《add_line》(state, "while " 加 cond 加 ":")。
    《indent_push》(state)。
    定义 i 等于 0。
    当 i 小于 《列表长度》(body)：
      《gen_stmt》(state, 《列表获取》(body, i))。
      i 加上 1。
    《indent_pop》(state)。
    返回。
  # For each loop: ["for_each", var_name, collection, body]
  如果 node_type 等于 "for_each"：
    定义 var_name 等于 《列表获取》(node, 1)。
    定义 collection 等于 《gen_expr》(state, 《列表获取》(node, 2))。
    定义 body 等于 《列表获取》(node, 3)。
    《add_line》(state, "for " 加 var_name 加 " in " 加 collection 加 ":")。
    《indent_push》(state)。
    定义 i 等于 0。
    当 i 小于 《列表长度》(body)：
      《gen_stmt》(state, 《列表获取》(body, i))。
      i 加上 1。
    《indent_pop》(state)。
    返回。
  # Print statement: ["print", value]
  如果 node_type 等于 "print"：
    定义 value 等于 《列表获取》(node, 1)。
    定义 val_code 等于 《gen_expr》(state, value)。
    《add_line》(state, "print(" 加 val_code 加 ")")。
    返回。
  # Function call as statement: ["func_call", name, args]
  如果 node_type 等于 "func_call"：
    定义 code 等于 《gen_expr》(state, node)。
    《add_line》(state, code)。
    返回。
  # Break statement: ["break"]
  如果 node_type 等于 "break"：
    《add_line》(state, "break")。
    返回。
  # Continue statement: ["continue"]
  如果 node_type 等于 "continue"：
    《add_line》(state, "continue")。
    返回。
  # Paragraph (function) definition: ["paragraph_def", name, params, body]
  # params 是 [name, default_expr] 对的列表，default_expr 为空表示无默认值
  如果 node_type 等于 "paragraph_def"：
    定义 name 等于 《列表获取》(node, 1)。
    定义 params 等于 《列表获取》(node, 2)。
    定义 body 等于 《列表获取》(node, 3)。
    定义 param_str 等于 ""。
    定义 i 等于 0。
    当 i 小于 《列表长度》(params)：
      如果 i 大于 0：
        设 param_str 为 param_str 加 ", "。
      定义 param_pair 等于 《列表获取》(params, i)。
      定义 pname 等于 《列表获取》(param_pair, 0)。
      定义 pdefault 等于 《列表获取》(param_pair, 1)。
      设 param_str 为 param_str 加 pname。
      如果 pdefault 不等于 空：
        定义 default_code 等于 《gen_expr》(state, pdefault)。
        设 param_str 为 param_str 加 "=" 加 default_code。
      i 加上 1。
    《add_line》(state, "def " 加 name 加 "(" 加 param_str 加 "):")。
    《indent_push》(state)。
    定义 j 等于 0。
    当 j 小于 《列表长度》(body)：
      《gen_stmt》(state, 《列表获取》(body, j))。
      j 加上 1。
    《indent_pop》(state)。
    《add_line》(state, "")。
    返回。
  # Expression statement: ["expr_stmt", expr]
  如果 node_type 等于 "expr_stmt"：
    定义 expr 等于 《列表获取》(node, 1)。
    定义 code 等于 《gen_expr》(state, expr)。
    《add_line》(state, code)。
    返回。
  # Default: skip unknown nodes
  返回。

# =============================================================================
# Import/Export header generation
# =============================================================================
段 gen_header 接收 state：
  《add_line》(state, "# Generated by Duan bootstrap compiler")。
  《add_line》(state, "import sys")。
  《add_line》(state, "import types")。
  《add_line》(state, "_duan_builtin = types.ModuleType('_duan_builtin')")。
  《add_line》(state, "_duan_builtin.打印 = print")。
  《add_line》(state, "_duan_builtin.转字符串 = str")。
  《add_line》(state, "_duan_builtin.转整数 = int")。
  《add_line》(state, "_duan_builtin.列表创建 = list")。
  《add_line》(state, "_duan_builtin.列表长度 = len")。
  《add_line》(state, "_duan_builtin.列表获取 = lambda lst, i: lst[i]")。
  《add_line》(state, "_duan_builtin.列表追加 = lambda lst, item: lst.append(item)")。
  《add_line》(state, "_duan_builtin.列表弹出 = lambda lst: lst.pop()")。
  《add_line》(state, "_duan_builtin.列表包含 = lambda lst, item: item in lst")。
  《add_line》(state, "_duan_builtin.字典创建 = dict")。
  定义 左花 为 "{"。
  定义 右花 为 "}"。
  《add_line》(state, "_duan_builtin.字典设置 = lambda d, k, v: d.update(" + 左花 + "k: v" + 右花 + ")")。
  《add_line》(state, "_duan_builtin.字典获取 = lambda d, k, default=None: d.get(k, default)")。
  《add_line》(state, "_duan_builtin.字典包含键 = lambda d, k: k in d")。
  《add_line》(state, "_duan_builtin.字典键列表 = lambda d: list(d.keys())")。
  《add_line》(state, "_duan_builtin.字符串长度 = len")。
  《add_line》(state, "_duan_builtin.字符串获取 = lambda s, i: s[i]")。
  《add_line》(state, "_duan_builtin.截取 = lambda s, start, end: s[start:end]")。
  《add_line》(state, "_duan_builtin.分割字符串 = lambda s, sep=' ': s.split(sep)")。
  《add_line》(state, "_duan_builtin.连接字符串 = lambda parts, sep='': sep.join(parts)")。
  《add_line》(state, "_duan_builtin.替换字符串 = lambda s, old, new: s.replace(old, new)")。
  《add_line》(state, "_duan_builtin.去除空白 = lambda s: s.strip()")。
  《add_line》(state, "_duan_builtin.列表排序 = lambda lst, reverse=False: lst.sort(reverse=reverse)")。
  《add_line》(state, "_duan_builtin.列表反转 = lambda lst: lst.reverse()")。
  《add_line》(state, "_duan_builtin.是整数 = lambda x: isinstance(x, int)")。
  《add_line》(state, "_duan_builtin.是浮点 = lambda x: isinstance(x, float)")。
  《add_line》(state, "_duan_builtin.是字符串 = lambda x: isinstance(x, str)")。
  《add_line》(state, "_duan_builtin.是列表 = lambda x: isinstance(x, list)")。
  《add_line》(state, "_duan_builtin.是字典 = lambda x: isinstance(x, dict)")。
  《add_line》(state, "_duan_builtin.是空 = lambda x: x is None")。
  《add_line》(state, "_duan_builtin.字典值列表 = lambda d: list(d.values())")。
  《add_line》(state, "_duan_builtin.字典项列表 = lambda d: list(d.items())")。
  《add_line》(state, "_duan_builtin.字典删除 = lambda d, k: d.pop(k, None)")。
  《add_line》(state, "_duan_builtin.随机整数 = lambda a, b: __import__('random').randint(a, b)")。
  《add_line》(state, "_duan_builtin.随机浮点 = lambda: __import__('random').random()")。
  《add_line》(state, "_duan_builtin.随机选择 = lambda lst: __import__('random').choice(lst)")。
  《add_line》(state, "_duan_builtin.阶乘 = lambda n: __import__('math').factorial(n)")。
  《add_line》(state, "_duan_builtin.平均数 = lambda data: sum(data) / len(data) if data else 0")。
  《add_line》(state, "_duan_builtin.求和 = lambda data: sum(data)")。
  《add_line》(state, "_duan_builtin.时间戳 = lambda: __import__('time').time()")。
  《add_line》(state, "_duan_builtin.格式化时间 = lambda ts, fmt='%Y-%m-%d %H:%M:%S': __import__('time').strftime(fmt, __import__('time').localtime(ts))")。
  《add_line》(state, "_duan_builtin.读取文件 = lambda path: open(path, 'r', encoding='utf-8').read()")。
  《add_line》(state, "_duan_builtin.写入文件 = lambda path, content: open(path, 'w', encoding='utf-8').write(content)")。
  《add_line》(state, "_duan_builtin.追加文件 = lambda path, content: open(path, 'a', encoding='utf-8').write(content)")。
  《add_line》(state, "_duan_builtin.文件存在 = lambda path: __import__('os').path.isfile(path)")。
  《add_line》(state, "_duan_builtin.目录存在 = lambda path: __import__('os').path.isdir(path)")。
  《add_line》(state, "_duan_builtin.创建目录 = lambda path: __import__('os').makedirs(path, exist_ok=True)")。
  《add_line》(state, "_duan_builtin.圆周率 = lambda: __import__('math').pi")。
  《add_line》(state, "_duan_builtin.自然常数 = lambda: __import__('math').e")。
  《add_line》(state, "_duan_builtin._读文件 = lambda path: open(path, 'r', encoding='utf-8').read()")。
  《add_line》(state, "")。
  # 全局绑定：在模块级别设置内建函数别名（在所有函数定义之前）
  《add_line》(state, "# 全局绑定：内建函数别名（模块级别，在函数定义之前）")。
  《add_line》(state, "字符串获取 = _duan_builtin.字符串获取")。
  《add_line》(state, "字符串长度 = _duan_builtin.字符串长度")。
  《add_line》(state, "截取 = _duan_builtin.截取")。
  《add_line》(state, "")。
  《add_line》(state, "")。

# =============================================================================
# Module-level initialization
# =============================================================================
段落 gen_module_init 接收 state：
  # 全局绑定：在函数定义之前设置
  《add_line》(state, "# 全局绑定：内建函数别名")。
  《add_line》(state, "字符串获取 = _duan_builtin.字符串获取")。
  《add_line》(state, "字符串长度 = _duan_builtin.字符串长度")。
  《add_line》(state, "截取 = _duan_builtin.截取")。
  《add_line》(state, "")。

# =============================================================================
# Main generate entry point
# =============================================================================
段 generate 接收 ast_node：
  # 先收集所有语句的代码
  定义 stmts_state 等于 《init_generator》()。
  定义 node_type 等于 《列表获取》(ast_node, 0)。
  如果 node_type 等于 "program"：
    定义 stmts 等于 《列表获取》(ast_node, 1)。
    定义 i 等于 0。
    当 i 小于 《列表长度》(stmts)：
      《gen_stmt》(stmts_state, 《列表获取》(stmts, i))。
      i 加上 1。
  # 获取语句代码
  定义 stmts_result 等于 《get_output》(stmts_state)。
  # 输出头部代码和全局绑定
  定义 state 等于 《init_generator》()。
  《gen_header》(state)。
  《gen_module_init》(state)。
  定义 header_result 等于 《get_output》(state)。
  # 组合：头部 + 语句
  返回 header_result 加 "\n" 加 stmts_result。
