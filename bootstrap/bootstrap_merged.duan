# ==================== token.duan ====================

# token.duan - Token 类型定义与构造函数
# 用于自举编译器
# 使用 ANTLR 规范语法：段落 段名 接收 参数：body结束。

导出 创建令牌, 令牌种别集, 是关键字, 符号种别。

# =============================================================================
# 创建令牌字典
# =============================================================================
段落 创建令牌 接收 种别, 值, 横, 纵：
  定义 令牌 等于 《字典创建》()。
  《字典设置》(令牌, "种别", 种别)。
  《字典设置》(令牌, "值", 值)。
  《字典设置》(令牌, "横", 横)。
  《字典设置》(令牌, "纵", 纵)。
  返回 令牌。

# =============================================================================
# 令牌种别常量
# =============================================================================
段落 令牌种别集：
  定义 种别字典 等于 《字典创建》()。
  《字典设置》(种别字典, "关键字", "关键字")。
  《字典设置》(种别字典, "标识符", "标识符")。
  《字典设置》(种别字典, "数字", "数字")。
  《字典设置》(种别字典, "字符串", "字符串")。
  《字典设置》(种别字典, "符号", "符号")。
  《字典设置》(种别字典, "结束", "结束")。
  返回 种别字典。

# =============================================================================
# 关键字检查
# =============================================================================
段落 是关键字 接收 文本：
  定义 关键字列表 等于 《列表创建》()。
  《列表追加》(关键字列表, "定义")。
  《列表追加》(关键字列表, "等于")。
  《列表追加》(关键字列表, "如果")。
  《列表追加》(关键字列表, "那么")。
  《列表追加》(关键字列表, "否则")。
  《列表追加》(关键字列表, "返回")。
  《列表追加》(关键字列表, "段落")。
  《列表追加》(关键字列表, "段")。
  《列表追加》(关键字列表, "接收")。
  《列表追加》(关键字列表, "当")。
  《列表追加》(关键字列表, "遍历")。
  《列表追加》(关键字列表, "跳过")。
  《列表追加》(关键字列表, "跳出")。
  《列表追加》(关键字列表, "打印")。
  《列表追加》(关键字列表, "导入")。
  《列表追加》(关键字列表, "导出")。
  《列表追加》(关键字列表, "设")。
  《列表追加》(关键字列表, "为")。
  《列表追加》(关键字列表, "从")。
  《列表追加》(关键字列表, "中的")。
  《列表追加》(关键字列表, "类")。
  《列表追加》(关键字列表, "接口")。
  《列表追加》(关键字列表, "尝试")。
  《列表追加》(关键字列表, "捕获")。
  《列表追加》(关键字列表, "抛出")。
  返回 《列表包含》(关键字列表, 文本)。

# =============================================================================
# 符号种别映射
# =============================================================================
段落 符号种别：
  定义 符号字典 等于 《字典创建》()。
  《字典设置》(符号字典, "。", "句号")。
  《字典设置》(符号字典, "，", "逗号")。
  《字典设置》(符号字典, "：", "冒号")。
  《字典设置》(符号字典, "（", "左括号")。
  《字典设置》(符号字典, "）", "右括号")。
  《字典设置》(符号字典, "【", "左方括号")。
  《字典设置》(符号字典, "】", "右方括号")。
  《字典设置》(符号字典, "《", "左书名号")。
  《字典设置》(符号字典, "》", "右书名号")。
  《字典设置》(符号字典, "=", "赋值")。
  《字典设置》(符号字典, "+", "加")。
  《字典设置》(符号字典, "-", "减")。
  《字典设置》(符号字典, "*", "乘")。
  《字典设置》(符号字典, "/", "除")。
  《字典设置》(符号字典, "%", "模")。
  《字典设置》(符号字典, "^", "幂")。
  《字典设置》(符号字典, "@", "标注")。
  《字典设置》(符号字典, ".", "点")。
  《字典设置》(符号字典, ",", "逗号")。
  返回 符号字典。


# ==================== duan_ast.duan ====================

# ast.duan - AST node constructors for bootstrap compiler
# Uses ANTLR规范语法: 段落 段名 接收 参数：body结束。
#
# Node format: list [type, data...]
# e.g. number literal = ["number", "42"]
#
# NOTE: All identifiers use English to avoid ANTLR keyword conflicts
# with single-character Chinese keywords (列=LIST, 段=SEGMENT, etc.)

导出 make_program。
导出 make_paragraph_def。
导出 make_var_decl。
导出 make_assign。
导出 make_compound_assign。
导出 make_if_stmt。
导出 make_while_loop。
导出 make_for_each。
导出 make_return。
导出 make_break。
导出 make_continue。
导出 make_print。
导出 make_expr_stmt。
导出 make_identifier。
导出 make_number。
导出 make_string。
导出 make_boolean。
导出 make_null。
导出 make_binary_op。
导出 make_unary_op。
导出 make_func_call。
导出 make_member_access。
导出 make_list_literal。
导出 make_dict_literal。
导出 make_template_string。
导出 node_type。
导出 node_data。

# =============================================================================
# Program node (root)
# =============================================================================
段 make_program 接收 stmt_list：
  定义 node 等于 《列表创建》()。
  《列表追加》(node, "program")。
  《列表追加》(node, stmt_list)。
  返回 node。

# =============================================================================
# Statement nodes
# =============================================================================
段 make_paragraph_def 接收 name, params, body：
  定义 node 等于 《列表创建》()。
  《列表追加》(node, "paragraph_def")。
  《列表追加》(node, name)。
  《列表追加》(node, params)。
  《列表追加》(node, body)。
  返回 node。

段 make_var_decl 接收 var_name, value：
  定义 node 等于 《列表创建》()。
  《列表追加》(node, "var_decl")。
  《列表追加》(node, var_name)。
  《列表追加》(node, value)。
  返回 node。

段 make_assign 接收 var_name, value：
  定义 node 等于 《列表创建》()。
  《列表追加》(node, "assign")。
  《列表追加》(node, var_name)。
  《列表追加》(node, value)。
  返回 node。

段 make_compound_assign 接收 var_name, op, value：
  定义 node 等于 《列表创建》()。
  《列表追加》(node, "compound_assign")。
  《列表追加》(node, var_name)。
  《列表追加》(node, op)。
  《列表追加》(node, value)。
  返回 node。

段 make_if_stmt 接收 cond, body, elif_branches, else_body：
  定义 node 等于 《列表创建》()。
  《列表追加》(node, "if_stmt")。
  《列表追加》(node, cond)。
  《列表追加》(node, body)。
  《列表追加》(node, elif_branches)。
  《列表追加》(node, else_body)。
  返回 node。

段 make_while_loop 接收 cond, body：
  定义 node 等于 《列表创建》()。
  《列表追加》(node, "while_loop")。
  《列表追加》(node, cond)。
  《列表追加》(node, body)。
  返回 node。

段 make_for_each 接收 var_name, collection, body：
  定义 node 等于 《列表创建》()。
  《列表追加》(node, "for_each")。
  《列表追加》(node, var_name)。
  《列表追加》(node, collection)。
  《列表追加》(node, body)。
  返回 node。

段 make_return 接收 value：
  定义 node 等于 《列表创建》()。
  《列表追加》(node, "return")。
  《列表追加》(node, value)。
  返回 node。

段 make_break：
  定义 node 等于 《列表创建》()。
  《列表追加》(node, "break")。
  返回 node。

段 make_continue：
  定义 node 等于 《列表创建》()。
  《列表追加》(node, "continue")。
  返回 node。

段 make_print 接收 value：
  定义 node 等于 《列表创建》()。
  《列表追加》(node, "print")。
  《列表追加》(node, value)。
  返回 node。

段 make_expr_stmt 接收 expr：
  定义 node 等于 《列表创建》()。
  《列表追加》(node, "expr_stmt")。
  《列表追加》(node, expr)。
  返回 node。

# =============================================================================
# Expression nodes
# =============================================================================
段 make_identifier 接收 name：
  定义 node 等于 《列表创建》()。
  《列表追加》(node, "identifier")。
  《列表追加》(node, name)。
  返回 node。

段 make_number 接收 value：
  定义 node 等于 《列表创建》()。
  《列表追加》(node, "number")。
  《列表追加》(node, value)。
  返回 node。

段 make_string 接收 value：
  定义 node 等于 《列表创建》()。
  《列表追加》(node, "string")。
  《列表追加》(node, value)。
  返回 node。

段 make_boolean 接收 value：
  定义 node 等于 《列表创建》()。
  《列表追加》(node, "boolean")。
  《列表追加》(node, value)。
  返回 node。

段 make_null：
  定义 node 等于 《列表创建》()。
  《列表追加》(node, "null")。
  返回 node。

段 make_binary_op 接收 op, left, right：
  定义 node 等于 《列表创建》()。
  《列表追加》(node, "binary_op")。
  《列表追加》(node, op)。
  《列表追加》(node, left)。
  《列表追加》(node, right)。
