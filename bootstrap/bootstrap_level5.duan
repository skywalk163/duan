# 段言自举编译器 - Level 4
# 支持完整的面向对象：属性访问、方法调用、继承
# 基于 Level 3，增加类的完整支持

段 关键字列表：
  返回 列表创建("设", "段落", "段", "返回", "结束", "为", "如果", "否则", "当", "接收", "加", "减", "乘", "除", "取模", "等于", "小于", "大于", "小于等于", "大于等于", "不等于", "且", "或", "非", "遍历", "在", "类", "属性", "己", "继承", "父")
结束。

段 是关键字 接收 w：
  设 kws 为 关键字列表()。
  设 i 为 0。
  当 i 小于 列表长度(kws)：
    如果 列表获取(kws, i) 等于 w：
      返回 真。
    结束。
    设 i 为 i 加 1。
  结束。
  返回 假。
结束。

段 是函数关键字 接收 w：
  如果 w 等于 "段落"：
    返回 真。
  结束。
  如果 w 等于 "段"：
    返回 真。
  结束。
  返回 假。
结束。

段 建 接收 t, v：
  返回 列表创建(t, v)。
结束。

段 词 接收 src, p, n, s：
  当 p 小于 n：
    设 c 为 字符串获取(src, p)。
    设 是分隔符 为 假。
    如果 c 等于 "："：
      设 是分隔符 为 真。
    结束。
    如果 c 等于 "。"：
      设 是分隔符 为 真。
    结束。
    如果 c 等于 "，"：
      设 是分隔符 为 真。
    结束。
    如果 是分隔符 等于 真：
      如果 s 等于 ""：
        返回 建("EOF", "")。
      结束。
      如果 是关键字(s)：
        返回 建("KW", s)。
      结束。
      返回 建("ID", s)。
    结束。
    设 是字母 为 假。
    如果 c 等于 "_"：
      设 是字母 为 真。
    结束。
    如果 c 大于等于 "a"：
      如果 c 小于等于 "z"：
        设 是字母 为 真。
      结束。
    结束。
    如果 c 大于等于 "A"：
      如果 c 小于等于 "Z"：
        设 是字母 为 真。
      结束。
    结束。
    如果 c 大于等于 "一"：
      设 是字母 为 真。
    结束。
    如果 是字母 等于 真：
      设 s 为 s 加 c。
      设 p 为 p 加 1。
    否则：
      设 是数字 为 假。
      如果 c 大于等于 "0"：
        如果 c 小于等于 "9"：
          设 是数字 为 真。
        结束。
      结束。
      如果 是数字 等于 真：
        如果 s 不等于 ""：
          设 s 为 s 加 c。
          设 p 为 p 加 1。
        否则：
          如果 s 等于 ""：
            返回 建("EOF", "")。
          结束。
          如果 是关键字(s)：
            返回 建("KW", s)。
          结束。
          返回 建("ID", s)。
        结束。
      否则：
        如果 s 等于 ""：
          返回 建("EOF", "")。
        结束。
        如果 是关键字(s)：
          返回 建("KW", s)。
        结束。
        返回 建("ID", s)。
      结束。
    结束。
  结束。
  如果 s 等于 ""：
    返回 建("EOF", "")。
  结束。
  如果 是关键字(s)：
    返回 建("KW", s)。
  结束。
  返回 建("ID", s)。
结束。

段 数字 接收 src, p, n, s：
  当 p 小于 n：
    设 c 为 字符串获取(src, p)。
    如果 c 大于等于 "0" 且 c 小于等于 "9"：
      设 s 为 s 加 c。
      设 p 为 p 加 1。
    否则：
      返回 建("NUM", s)。
    结束。
  结束。
  返回 建("NUM", s)。
结束。

段 字符串 接收 src, p, n, s：
  当 p 小于 n：
    设 c 为 字符串获取(src, p)。
    如果 c 等于 '"'：
      设 tok 为 建("STR", s)。
      返回 列表创建(tok, p 加 1)。
    结束。
    设 s 为 s 加 c。
    设 p 为 p 加 1。
  结束。
  设 tok 为 建("STR", s)。
  返回 列表创建(tok, p)。
结束。

段 扫注释 接收 src, p, n：
  当 p 小于 n：
    设 c 为 字符串获取(src, p)。
    如果 c 等于 "\n"：
      返回 p 加 1。
    结束。
    设 p 为 p 加 1。
  结束。
  返回 p。
结束。

段 扫 接收 src, p, n, toks：
  当 p 小于 n：
    设 c 为 字符串获取(src, p)。
    设 已处理 为 假。
    如果 c 等于 " "：
      设 p 为 p 加 1。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假 且 c 等于 "\n"：
      设 p 为 p 加 1。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假 且 c 等于 "#"：
      设 p 为 扫注释(src, p 加 1, n)。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假 且 c 等于 "'"：
      如果 p 加 1 小于 n：
        设 nc 为 字符串获取(src, p 加 1)。
        如果 nc 等于 '"'：
          列表追加(toks, 建("STR", '"'))
          设 p 为 p 加 3。
          设 已处理 为 真。
        结束。
      结束。
      如果 已处理 等于 假：
        设 p 为 p 加 1。
        设 已处理 为 真。
      结束。
    结束。
    如果 已处理 等于 假 且 c 等于 '"'：
      如果 p 加 1 小于 n：
        设 nc 为 字符串获取(src, p 加 1)。
        如果 nc 等于 "'"：
          列表追加(toks, 建("STR", "'"))
          设 p 为 p 加 3。
          设 已处理 为 真。
        结束。
      结束。
      如果 已处理 等于 假：
        设 结果 为 字符串(src, p 加 1, n, "")。
        设 tok 为 列表获取(结果, 0)。
        设 p 为 列表获取(结果, 1)。
        列表追加(toks, tok)。
        设 已处理 为 真。
      结束。
    结束。
    如果 已处理 等于 假 且 c 等于 "："：
      设 p 为 p 加 1。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假 且 c 等于 "。"：
      设 p 为 p 加 1。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假 且 c 等于 "，"：
      设 p 为 p 加 1。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假 且 c 等于 "("：
      列表追加(toks, 建("LPAREN", "("))
      设 p 为 p 加 1。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假 且 c 等于 ")"：
      列表追加(toks, 建("RPAREN", ")"))
      设 p 为 p 加 1。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假 且 c 等于 ","：
      列表追加(toks, 建("COMMA", ","))
      设 p 为 p 加 1。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假 且 c 等于 "."：
      列表追加(toks, 建("DOT", "."))
      设 p 为 p 加 1。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假 且 c 大于等于 "0"：
      如果 c 小于等于 "9"：
        设 tok 为 数字(src, p, n, "")。
        列表追加(toks, tok)。
        设 p 为 p 加 字符串长度(列表获取(tok, 1))。
        设 已处理 为 真。
      结束。
    结束。
    如果 已处理 等于 假 且 c 大于等于 "a"：
      设 tok 为 词(src, p, n, "")。
      列表追加(toks, tok)。
      设 p 为 p 加 字符串长度(列表获取(tok, 1))。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假 且 c 大于等于 "A"：
      设 tok 为 词(src, p, n, "")。
      列表追加(toks, tok)。
      设 p 为 p 加 字符串长度(列表获取(tok, 1))。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假 且 c 大于等于 "一"：
      设 tok 为 词(src, p, n, "")。
      列表追加(toks, tok)。
      设 p 为 p 加 字符串长度(列表获取(tok, 1))。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假：
      设 p 为 p 加 1。
    结束。
  结束。
  返回 toks。
结束。

段 词法 接收 src：
  返回 扫(src, 0, 字符串长度(src), 列表创建())。
结束。

段 表达式 接收 toks, p：
  返回 或表达式(toks, p)。
结束。

段 或表达式 接收 toks, p：
  设 结果 为 且表达式(toks, p)。
  设 left 为 列表获取(结果, 0)。
  设 np 为 列表获取(结果, 1)。
  设 继续循环 为 真。
  当 继续循环 且 np 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, np)。
    设 tv 为 列表获取(tok, 1)。
    如果 tv 不等于 "或"：
      设 继续循环 为 假。
    否则：
      设 右结果 为 且表达式(toks, np 加 1)。
      设 right 为 列表获取(右结果, 0)。
      设 np 为 列表获取(右结果, 1)。
      设 left 为 left 加 " or " 加 right。
    结束。
  结束。
  返回 列表创建(left, np)。
结束。

段 且表达式 接收 toks, p：
  设 结果 为 比较表达式(toks, p)。
  设 left 为 列表获取(结果, 0)。
  设 np 为 列表获取(结果, 1)。
  设 继续循环 为 真。
  当 继续循环 且 np 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, np)。
    设 tv 为 列表获取(tok, 1)。
    如果 tv 不等于 "且"：
      设 继续循环 为 假。
    否则：
      设 右结果 为 比较表达式(toks, np 加 1)。
      设 right 为 列表获取(右结果, 0)。
      设 np 为 列表获取(右结果, 1)。
      设 left 为 left 加 " and " 加 right。
    结束。
  结束。
  返回 列表创建(left, np)。
结束。

段 比较表达式 接收 toks, p：
  设 结果 为 加减表达式(toks, p)。
  设 left 为 列表获取(结果, 0)。
  设 np 为 列表获取(结果, 1)。
  如果 np 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, np)。
    设 tv 为 列表获取(tok, 1)。
    如果 tv 等于 "等于"：
      设 右结果 为 加减表达式(toks, np 加 1)。
      设 right 为 列表获取(右结果, 0)。
      设 np 为 列表获取(右结果, 1)。
      返回 列表创建(left 加 " == " 加 right, np)。
    结束。
    如果 tv 等于 "小于"：
      设 右结果 为 加减表达式(toks, np 加 1)。
      设 right 为 列表获取(右结果, 0)。
      设 np 为 列表获取(右结果, 1)。
      返回 列表创建(left 加 " < " 加 right, np)。
    结束。
    如果 tv 等于 "大于"：
      设 右结果 为 加减表达式(toks, np 加 1)。
      设 right 为 列表获取(右结果, 0)。
      设 np 为 列表获取(右结果, 1)。
      返回 列表创建(left 加 " > " 加 right, np)。
    结束。
    如果 tv 等于 "小于等于"：
      设 右结果 为 加减表达式(toks, np 加 1)。
      设 right 为 列表获取(右结果, 0)。
      设 np 为 列表获取(右结果, 1)。
      返回 列表创建(left 加 " <= " 加 right, np)。
    结束。
    如果 tv 等于 "大于等于"：
      设 右结果 为 加减表达式(toks, np 加 1)。
      设 right 为 列表获取(右结果, 0)。
      设 np 为 列表获取(右结果, 1)。
      返回 列表创建(left 加 " >= " 加 right, np)。
    结束。
    如果 tv 等于 "不等于"：
      设 右结果 为 加减表达式(toks, np 加 1)。
      设 right 为 列表获取(右结果, 0)。
      设 np 为 列表获取(右结果, 1)。
      返回 列表创建(left 加 " != " 加 right, np)。
    结束。
  结束。
  返回 列表创建(left, np)。
结束。

段 加减表达式 接收 toks, p：
  设 结果 为 乘除表达式(toks, p)。
  设 left 为 列表获取(结果, 0)。
  设 np 为 列表获取(结果, 1)。
  设 继续循环 为 真。
  当 继续循环 且 np 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, np)。
    设 tv 为 列表获取(tok, 1)。
    如果 tv 等于 "加"：
      设 右结果 为 乘除表达式(toks, np 加 1)。
      设 right 为 列表获取(右结果, 0)。
      设 np 为 列表获取(右结果, 1)。
      设 left 为 left 加 " + " 加 right。
    否则：
      如果 tv 等于 "减"：
        设 右结果 为 乘除表达式(toks, np 加 1)。
        设 right 为 列表获取(右结果, 0)。
        设 np 为 列表获取(右结果, 1)。
        设 left 为 left 加 " - " 加 right。
      否则：
        设 继续循环 为 假。
      结束。
    结束。
  结束。
  返回 列表创建(left, np)。
结束。

段 乘除表达式 接收 toks, p：
  设 结果 为 成员表达式(toks, p)。
  设 left 为 列表获取(结果, 0)。
  设 np 为 列表获取(结果, 1)。
  设 继续循环 为 真。
  当 继续循环 且 np 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, np)。
    设 tv 为 列表获取(tok, 1)。
    如果 tv 等于 "乘"：
      设 右结果 为 成员表达式(toks, np 加 1)。
      设 right 为 列表获取(右结果, 0)。
      设 np 为 列表获取(右结果, 1)。
      设 left 为 left 加 " * " 加 right。
    否则：
      如果 tv 等于 "除"：
        设 右结果 为 成员表达式(toks, np 加 1)。
        设 right 为 列表获取(右结果, 0)。
        设 np 为 列表获取(右结果, 1)。
        设 left 为 left 加 " // " 加 right。
      否则：
        如果 tv 等于 "取模"：
          设 右结果 为 成员表达式(toks, np 加 1)。
          设 right 为 列表获取(右结果, 0)。
          设 np 为 列表获取(右结果, 1)。
          设 left 为 left 加 " % " 加 right。
        否则：
          设 继续循环 为 假。
        结束。
      结束。
    结束。
  结束。
  返回 列表创建(left, np)。
结束。

段 成员表达式 接收 toks, p：
  设 结果 为 一元表达式(toks, p)。
  设 left 为 列表获取(结果, 0)。
  设 np 为 列表获取(结果, 1)。
  返回 处理成员链(toks, np, left)。
结束。

段 处理成员链 接收 toks, p, left：
  设 np 为 p。
  当 np 小于 列表长度(toks)：
    设 dot_tok 为 列表获取(toks, np)。
    如果 列表获取(dot_tok, 0) 等于 "DOT"：
      设 np 为 np 加 1。
      如果 np 小于 列表长度(toks)：
        设 attr_tok 为 列表获取(toks, np)。
        设 attr_name 为 列表获取(attr_tok, 1)。
        设 np 为 np 加 1。
        如果 np 小于 列表长度(toks)：
          设 next_tok 为 列表获取(toks, np)。
          如果 列表获取(next_tok, 0) 等于 "LPAREN"：
            设 参数结果 为 解析参数列表(toks, np 加 1)。
            设 args 为 列表获取(参数结果, 0)。
            设 np 为 列表获取(参数结果, 1)。
            设 left 为 left 加 "." 加 attr_name 加 "(" 加 args 加 ")"。
          否则：
            设 left 为 left 加 "." 加 attr_name。
          结束。
        否则：
          设 left 为 left 加 "." 加 attr_name。
        结束。
      结束。
    否则：
      返回 列表创建(left, np)。
    结束。
  结束。
  返回 列表创建(left, np)。
结束。

段 一元表达式 接收 toks, p：
  如果 p 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, p)。
    如果 列表获取(tok, 0) 等于 "KW" 且 列表获取(tok, 1) 等于 "非"：
      设 结果 为 一元表达式(toks, p 加 1)。
      设 expr 为 列表获取(结果, 0)。
      设 np 为 列表获取(结果, 1)。
      返回 列表创建("not " 加 expr, np)。
    结束。
    如果 列表获取(tok, 0) 等于 "KW" 且 列表获取(tok, 1) 等于 "己"：
      返回 处理成员链(toks, p 加 1, "self")。
    结束。
    如果 列表获取(tok, 0) 等于 "KW" 且 列表获取(tok, 1) 等于 "父"：
      返回 处理成员链(toks, p 加 1, "super()")。
    结束。
    如果 列表获取(tok, 0) 等于 "LPAREN"：
      设 结果 为 表达式(toks, p 加 1)。
      设 expr 为 列表获取(结果, 0)。
      设 np 为 列表获取(结果, 1)。
      如果 np 小于 列表长度(toks)：
        设 tok 为 列表获取(toks, np)。
        如果 列表获取(tok, 0) 等于 "RPAREN"：
          返回 列表创建(expr, np 加 1)。
        结束。
      结束。
      返回 列表创建(expr, np)。
    结束。
    如果 列表获取(tok, 0) 等于 "NUM"：
      返回 列表创建(列表获取(tok, 1), p 加 1)。
    结束。
    如果 列表获取(tok, 0) 等于 "STR"：
      设 s 为 列表获取(tok, 1)。
      设 有单引号 为 假。
      设 i 为 0。
      当 i 小于 字符串长度(s)：
        如果 字符串获取(s, i) 等于 "'"：
          设 有单引号 为 真。
        结束。
        设 i 为 i 加 1。
      结束。
      如果 有单引号：
        返回 列表创建('"' 加 s 加 '"', p 加 1)。
      结束。
      返回 列表创建("'" 加 s 加 "'", p 加 1)。
    结束。
    如果 列表获取(tok, 0) 等于 "ID"：
      设 name 为 列表获取(tok, 1)。
      设 np 为 p 加 1。
      如果 np 小于 列表长度(toks)：
        设 tok 为 列表获取(toks, np)。
        如果 列表获取(tok, 0) 等于 "LPAREN"：
          设 参数结果 为 解析参数列表(toks, np 加 1)。
          设 args 为 列表获取(参数结果, 0)。
          设 np 为 列表获取(参数结果, 1)。
          返回 列表创建(name 加 "(" 加 args 加 ")", np)。
        结束。
      结束。
      返回 列表创建(name, np)。
    结束。
  结束。
  返回 列表创建("None", p)。
结束。

段 解析参数列表 接收 toks, p：
  如果 p 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, p)。
    如果 列表获取(tok, 0) 等于 "RPAREN"：
      返回 列表创建("", p 加 1)。
    结束。
    设 结果 为 表达式(toks, p)。
    设 first 为 列表获取(结果, 0)。
    设 np 为 列表获取(结果, 1)。
    设 剩余结果 为 解析更多参数(toks, np, first)。
    返回 剩余结果。
  结束。
  返回 列表创建("", p)。
结束。

段 解析更多参数 接收 toks, p, acc：
  当 p 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, p)。
    如果 列表获取(tok, 0) 等于 "RPAREN"：
      返回 列表创建(acc, p 加 1)。
    结束。
    如果 列表获取(tok, 0) 等于 "COMMA"：
      设 结果 为 表达式(toks, p 加 1)。
      设 next_arg 为 列表获取(结果, 0)。
      设 np 为 列表获取(结果, 1)。
      设 acc 为 acc 加 ", " 加 next_arg。
      设 p 为 np。
    否则：
      设 p 为 p 加 1。
    结束。
  结束。
  返回 列表创建(acc, p)。
结束。

段 find_ret 接收 toks, p：
  如果 p 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, p)。
    如果 列表获取(tok, 1) 等于 "返回"：
      设 结果 为 表达式(toks, p 加 1)。
      设 expr 为 列表获取(结果, 0)。
      设 np 为 列表获取(结果, 1)。
      返回 列表创建("return " 加 expr, np)。
    结束。
  结束。
  返回 列表创建("pass", p)。
结束。

段 find_end 接收 toks, p：
  当 p 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, p)。
    如果 列表获取(tok, 0) 等于 "KW"：
      如果 列表获取(tok, 1) 等于 "结束"：
        返回 p 加 1。
      结束。
      如果 是函数关键字(列表获取(tok, 1))：
        返回 p。
      结束。
    结束。
    设 p 为 p 加 1。
  结束。
  返回 p。
结束。

段 find_next 接收 toks, p：
  当 p 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, p)。
    如果 列表获取(tok, 0) 等于 "KW"：
      设 tv 为 列表获取(tok, 1)。
      如果 是函数关键字(tv)：
        返回 p。
      结束。
      如果 tv 等于 "结束"：
        返回 p。
      结束。
      如果 tv 等于 "设"：
        返回 p。
      结束。
      如果 tv 等于 "如果"：
        返回 p。
      结束。
      如果 tv 等于 "返回"：
        返回 p。
      结束。
    结束。
    设 p 为 p 加 1。
  结束。
  返回 p。
结束。

段 comp_set 接收 toks, p：
  如果 p 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, p)。
    如果 列表获取(tok, 1) 等于 "设"：
      设 np 为 p 加 1。
      如果 np 小于 列表长度(toks)：
        设 first_tok 为 列表获取(toks, np)。
        如果 列表获取(first_tok, 0) 等于 "KW" 且 列表获取(first_tok, 1) 等于 "己"：
          设 var_expr 为 "self"。
          设 np 为 np 加 1。
          设 继续循环 为 真。
          当 继续循环 等于 真 且 np 小于 列表长度(toks)：
            设 dot_tok 为 列表获取(toks, np)。
            如果 列表获取(dot_tok, 0) 等于 "DOT"：
              设 np 为 np 加 1。
              如果 np 小于 列表长度(toks)：
                设 attr_tok 为 列表获取(toks, np)。
                设 attr_name 为 列表获取(attr_tok, 1)。
                设 var_expr 为 var_expr 加 "." 加 attr_name。
                设 np 为 np 加 1。
              结束。
            否则：
              设 继续循环 为 假。
            结束。
          结束。
          如果 np 小于 列表长度(toks)：
            设 tok 为 列表获取(toks, np)。
            如果 列表获取(tok, 1) 等于 "为"：
              设 np 为 np 加 1。
              设 结果 为 表达式(toks, np)。
              设 expr 为 列表获取(结果, 0)。
              设 np 为 列表获取(结果, 1)。
              返回 列表创建(var_expr 加 " = " 加 expr, np)。
            结束。
          结束。
        否则：
          设 var 为 列表获取(first_tok, 1)。
          设 np 为 np 加 1。
          如果 np 小于 列表长度(toks)：
            设 tok 为 列表获取(toks, np)。
            如果 列表获取(tok, 1) 等于 "为"：
              设 np 为 np 加 1。
              设 结果 为 表达式(toks, np)。
              设 expr 为 列表获取(结果, 0)。
              设 np 为 列表获取(结果, 1)。
              返回 列表创建(var 加 " = " 加 expr, np)。
            结束。
          结束。
        结束。
      结束。
      返回 列表创建("", p 加 1)。
    结束。
  结束。
  返回 列表创建("", p)。
结束。

段 find_matching_end 接收 toks, p, level：
  当 p 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, p)。
    如果 列表获取(tok, 0) 等于 "KW"：
      设 tv 为 列表获取(tok, 1)。
      如果 tv 等于 "如果"：
        设 level 为 level 加 1。
      结束。
      如果 tv 等于 "当"：
        设 level 为 level 加 1。
      结束。
      如果 tv 等于 "遍历"：
        设 level 为 level 加 1。
      结束。
      如果 tv 等于 "类"：
        设 level 为 level 加 1。
      结束。
      如果 tv 等于 "段落"：
        设 level 为 level 加 1。
      结束。
      如果 tv 等于 "段"：
        设 level 为 level 加 1。
      结束。
      如果 tv 等于 "否则"：
        如果 level 等于 1：
          返回 p。
        结束。
      结束。
      如果 tv 等于 "结束"：
        如果 level 等于 1：
          返回 p 加 1。
        结束。
        设 level 为 level 减 1。
      结束。
    结束。
    设 p 为 p 加 1。
  结束。
  返回 p。
结束。

段 compile_block 接收 toks, p, end_p, indent, out：
  当 p 小于 end_p：
    如果 p 小于 列表长度(toks)：
      设 tok 为 列表获取(toks, p)。
      设 tv 为 列表获取(tok, 1)。
      设 已处理 为 假。
      如果 tv 等于 "设"：
        设 结果 为 comp_set(toks, p)。
        设 stmt 为 列表获取(结果, 0)。
        设 np 为 列表获取(结果, 1)。
        设 out 为 out 加 indent 加 stmt 加 "\n"。
        设 p 为 np。
        设 已处理 为 真。
      结束。
      如果 已处理 等于 假 且 tv 等于 "如果"：
        设 结果 为 comp_if(toks, p)。
        设 stmt 为 列表获取(结果, 0)。
        设 np 为 列表获取(结果, 1)。
        设 out 为 out 加 add_indent(stmt, indent)。
        设 p 为 np。
        设 已处理 为 真。
      结束。
      如果 已处理 等于 假 且 tv 等于 "当"：
        设 结果 为 comp_while(toks, p)。
        设 stmt 为 列表获取(结果, 0)。
        设 np 为 列表获取(结果, 1)。
        设 out 为 out 加 add_indent(stmt, indent)。
        设 p 为 np。
        设 已处理 为 真。
      结束。
      如果 已处理 等于 假 且 tv 等于 "遍历"：
        设 结果 为 comp_for(toks, p)。
        设 stmt 为 列表获取(结果, 0)。
        设 np 为 列表获取(结果, 1)。
        设 out 为 out 加 add_indent(stmt, indent)。
        设 p 为 np。
        设 已处理 为 真。
      结束。
      如果 已处理 等于 假 且 tv 等于 "返回"：
        设 结果 为 find_ret(toks, p)。
        设 stmt 为 列表获取(结果, 0)。
        设 np 为 列表获取(结果, 1)。
        设 out 为 out 加 indent 加 stmt 加 "\n"。
        设 p 为 np。
        设 已处理 为 真。
      结束。
      如果 已处理 等于 假 且 列表获取(tok, 0) 等于 "ID"：
        设 np 为 p 加 1。
        如果 np 小于 列表长度(toks)：
          设 ntok 为 列表获取(toks, np)。
          如果 列表获取(ntok, 0) 等于 "LPAREN"：
            设 结果 为 表达式(toks, p)。
            设 stmt 为 列表获取(结果, 0)。
            设 np 为 列表获取(结果, 1)。
            设 out 为 out 加 indent 加 stmt 加 "\n"。
            设 p 为 np。
            设 已处理 为 真。
          结束。
          如果 已处理 等于 假 且 列表获取(ntok, 0) 等于 "DOT"：
            设 结果 为 表达式(toks, p)。
            设 stmt 为 列表获取(结果, 0)。
            设 np 为 列表获取(结果, 1)。
            设 out 为 out 加 indent 加 stmt 加 "\n"。
            设 p 为 np。
            设 已处理 为 真。
          结束。
        结束。
      结束。
      如果 已处理 等于 假 且 列表获取(tok, 0) 等于 "KW" 且 tv 等于 "父"：
        设 np 为 p 加 1。
        如果 np 小于 列表长度(toks)：
          设 ntok 为 列表获取(toks, np)。
          如果 列表获取(ntok, 0) 等于 "DOT"：
            设 结果 为 表达式(toks, p)。
            设 stmt 为 列表获取(结果, 0)。
            设 np 为 列表获取(结果, 1)。
            设 out 为 out 加 indent 加 stmt 加 "\n"。
            设 p 为 np。
            设 已处理 为 真。
          结束。
        结束。
      结束。
      如果 已处理 等于 假 且 列表获取(tok, 0) 等于 "DOT"：
        设 已处理 为 真。
        设 p 为 p 加 1。
      结束。
      如果 已处理 等于 假 且 tv 等于 "结束"：
        返回 out。
      结束。
      如果 已处理 等于 假：
        设 p 为 p 加 1。
      结束。
    结束。
  结束。
  返回 out。
结束。

段 add_indent 接收 text, indent：
  设 有尾换行 为 假。
  如果 字符串长度(text) 大于 0：
    设 末字符 为 字符串获取(text, 字符串长度(text) 减 1)。
    如果 末字符 等于 "\n"：
      设 有尾换行 为 真。
    结束。
  结束。
  如果 有尾换行：
    设 text 为 截取(text, 0, 字符串长度(text) 减 1)。
  结束。
  设 结果 为 indent 加 加缩进行(text, indent, "", 0)。
  如果 有尾换行：
    返回 结果 加 "\n"。
  结束。
  返回 结果。
结束。

段 加缩进行 接收 text, indent, acc, i：
  当 i 小于 字符串长度(text)：
    设 c 为 字符串获取(text, i)。
    如果 c 等于 "\n"：
      设 acc 为 acc 加 "\n" 加 indent。
    否则：
      设 acc 为 acc 加 c。
    结束。
    设 i 为 i 加 1。
  结束。
  返回 acc。
结束。

段 comp_if 接收 toks, p：
  如果 p 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, p)。
    如果 列表获取(tok, 1) 等于 "如果"：
      设 np 为 p 加 1。
      设 结果 为 表达式(toks, np)。
      设 cond 为 列表获取(结果, 0)。
      设 np 为 列表获取(结果, 1)。
      设 end_p 为 find_matching_end(toks, np, 1)。
      设 body 为 compile_block(toks, np, end_p 减 1, "    ", "")。
      如果 body 等于 ""：
        设 body 为 "    pass\n"。
      结束。
      设 code 为 "if " 加 cond 加 ":\n" 加 body。
      如果 end_p 小于 列表长度(toks)：
        设 next_tok 为 列表获取(toks, end_p)。
        如果 列表获取(next_tok, 1) 等于 "否则"：
          设 else_p 为 end_p 加 1。
          设 else_end 为 find_matching_end(toks, else_p, 1)。
          设 else_body 为 compile_block(toks, else_p, else_end 减 1, "    ", "")。
          如果 else_body 等于 ""：
            设 else_body 为 "    pass"。
          结束。
          设 code 为 code 加 "\nelse:\n" 加 else_body。
          返回 列表创建(code, else_end)。
        结束。
      结束。
      返回 列表创建(code, end_p)。
    结束。
  结束。
  返回 列表创建("", p)。
结束。

段 comp_while 接收 toks, p：
  如果 p 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, p)。
    如果 列表获取(tok, 1) 等于 "当"：
      设 np 为 p 加 1。
      设 结果 为 表达式(toks, np)。
      设 cond 为 列表获取(结果, 0)。
      设 np 为 列表获取(结果, 1)。
      设 end_p 为 find_matching_end(toks, np, 1)。
      设 body 为 compile_block(toks, np, end_p 减 1, "    ", "")。
      如果 body 等于 ""：
        设 body 为 "    pass\n"。
      结束。
      返回 列表创建("while " 加 cond 加 ":\n" 加 body, end_p)。
    结束。
  结束。
  返回 列表创建("", p)。
结束。

段 comp_for 接收 toks, p：
  如果 p 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, p)。
    如果 列表获取(tok, 1) 等于 "遍历"：
      设 np 为 p 加 1。
      如果 np 小于 列表长度(toks)：
        设 var_tok 为 列表获取(toks, np)。
        设 var_name 为 列表获取(var_tok, 1)。
        设 np 为 np 加 1。
        如果 np 小于 列表长度(toks)：
          设 next_tok 为 列表获取(toks, np)。
          如果 列表获取(next_tok, 1) 等于 "在"：
            设 np 为 np 加 1。
            设 结果 为 表达式(toks, np)。
            设 iter_expr 为 列表获取(结果, 0)。
            设 np 为 列表获取(结果, 1)。
            设 end_p 为 find_matching_end(toks, np, 1)。
            设 body 为 compile_block(toks, np, end_p 减 1, "    ", "")。
            如果 body 等于 ""：
              设 body 为 "    pass\n"。
            结束。
            返回 列表创建("for " 加 var_name 加 " in " 加 iter_expr 加 ":\n" 加 body, end_p)。
          结束。
        结束。
      结束。
    结束。
  结束。
  返回 列表创建("", p)。
结束。

段 compile_stmts 接收 toks, p, out：
  当 p 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, p)。
    设 tv 为 列表获取(tok, 1)。
    设 已处理 为 假。
    如果 tv 等于 "设"：
      设 结果 为 comp_set(toks, p)。
      设 stmt 为 列表获取(结果, 0)。
      设 np 为 列表获取(结果, 1)。
      设 out 为 out 加 "    " 加 stmt 加 "\n"。
      设 p 为 np。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假 且 tv 等于 "如果"：
      设 结果 为 comp_if(toks, p)。
      设 stmt 为 列表获取(结果, 0)。
      设 np 为 列表获取(结果, 1)。
      设 out 为 out 加 add_indent(stmt, "    ")。
      设 p 为 np。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假 且 tv 等于 "当"：
      设 结果 为 comp_while(toks, p)。
      设 stmt 为 列表获取(结果, 0)。
      设 np 为 列表获取(结果, 1)。
      设 out 为 out 加 add_indent(stmt, "    ")。
      设 p 为 np。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假 且 tv 等于 "遍历"：
      设 结果 为 comp_for(toks, p)。
      设 stmt 为 列表获取(结果, 0)。
      设 np 为 列表获取(结果, 1)。
      设 out 为 out 加 add_indent(stmt, "    ")。
      设 p 为 np。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假 且 tv 等于 "返回"：
      设 结果 为 find_ret(toks, p)。
      设 stmt 为 列表获取(结果, 0)。
      设 np 为 列表获取(结果, 1)。
      设 out 为 out 加 "    " 加 stmt 加 "\n"。
      设 p 为 np。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假 且 列表获取(tok, 0) 等于 "ID"：
      设 np 为 p 加 1。
      如果 np 小于 列表长度(toks)：
        设 ntok 为 列表获取(toks, np)。
        如果 列表获取(ntok, 0) 等于 "LPAREN"：
          设 结果 为 表达式(toks, p)。
          设 stmt 为 列表获取(结果, 0)。
          设 np 为 列表获取(结果, 1)。
          设 out 为 out 加 "    " 加 stmt 加 "\n"。
          设 p 为 np。
          设 已处理 为 真。
        结束。
        如果 已处理 等于 假 且 列表获取(ntok, 0) 等于 "DOT"：
          设 结果 为 表达式(toks, p)。
          设 stmt 为 列表获取(结果, 0)。
          设 np 为 列表获取(结果, 1)。
          设 out 为 out 加 "    " 加 stmt 加 "\n"。
          设 p 为 np。
          设 已处理 为 真。
        结束。
      结束。
    结束。
    如果 已处理 等于 假 且 列表获取(tok, 0) 等于 "KW" 且 tv 等于 "父"：
      设 np 为 p 加 1。
      如果 np 小于 列表长度(toks)：
        设 ntok 为 列表获取(toks, np)。
        如果 列表获取(ntok, 0) 等于 "DOT"：
          设 结果 为 表达式(toks, p)。
          设 stmt 为 列表获取(结果, 0)。
          设 np 为 列表获取(结果, 1)。
          设 out 为 out 加 "    " 加 stmt 加 "\n"。
          设 p 为 np。
          设 已处理 为 真。
        结束。
      结束。
    结束。
    如果 已处理 等于 假 且 tv 等于 "结束"：
      返回 列表创建(out, p 加 1)。
    结束。
    如果 已处理 等于 假 且 是函数关键字(tv)：
      返回 列表创建(out, p)。
    结束。
    如果 已处理 等于 假：
      设 p 为 p 加 1。
    结束。
  结束。
  返回 列表创建(out, p)。
结束。

段 解析参数 接收 toks, p：
  如果 p 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, p)。
    如果 列表获取(tok, 1) 等于 "接收"：
      返回 收集参数(toks, p 加 1, "")。
    结束。
  结束。
  返回 列表创建("", p)。
结束。

段 收集参数 接收 toks, p, acc：
  当 p 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, p)。
    设 已处理 为 假。
    如果 列表获取(tok, 0) 等于 "ID"：
      设 v 为 列表获取(tok, 1)。
      如果 字符串长度(v) 大于 0：
        设 末字符 为 字符串获取(v, 字符串长度(v) 减 1)。
        如果 末字符 等于 "："：
          设 v 为 截取(v, 0, 字符串长度(v) 减 1)。
          如果 acc 等于 ""：
            返回 列表创建(v, p 加 1)。
          结束。
          返回 列表创建(acc 加 ", " 加 v, p 加 1)。
        结束。
      结束。
      如果 acc 等于 ""：
        设 acc 为 v。
      否则：
        设 acc 为 acc 加 ", " 加 v。
      结束。
      设 p 为 p 加 1。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假 且 列表获取(tok, 0) 等于 "KW"：
      设 v 为 列表获取(tok, 1)。
      如果 v 等于 "己"：
        如果 acc 等于 ""：
          设 acc 为 v。
        否则：
          设 acc 为 acc 加 ", " 加 v。
        结束。
        设 p 为 p 加 1。
        设 已处理 为 真。
      结束。
    结束。
    如果 已处理 等于 假 且 列表获取(tok, 0) 等于 "COMMA"：
      设 p 为 p 加 1。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假：
      返回 列表创建(acc, p)。
    结束。
  结束。
  返回 列表创建(acc, p)。
结束。

段 compile_class 接收 toks, p：
  如果 p 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, p)。
    如果 列表获取(tok, 1) 等于 "类"：
      设 np 为 p 加 1。
      设 name 为 ""。
      如果 np 小于 列表长度(toks)：
        设 name_tok 为 列表获取(toks, np)。
        设 name 为 列表获取(name_tok, 1)。
        设 np 为 np 加 1。
      结束。
      设 parent_name 为 ""。
      如果 np 小于 列表长度(toks)：
        设 next_tok 为 列表获取(toks, np)。
        如果 列表获取(next_tok, 0) 等于 "LPAREN"：
          设 np 为 np 加 1。
          如果 np 小于 列表长度(toks)：
            设 parent_tok 为 列表获取(toks, np)。
            设 parent_name 为 列表获取(parent_tok, 1)。
            设 np 为 np 加 1。
            如果 np 小于 列表长度(toks)：
              设 rparen_tok 为 列表获取(toks, np)。
              如果 列表获取(rparen_tok, 0) 等于 "RPAREN"：
                设 np 为 np 加 1。
              结束。
            结束。
          结束。
        结束。
      结束。
      设 end_p 为 find_matching_end(toks, np, 1)。
      设 body 为 compile_class_body(toks, np, end_p 减 1, name)。
      如果 body 等于 ""：
        设 body 为 "    pass"。
      结束。
      设 class_def 为 "class " 加 name。
      如果 parent_name 不等于 ""：
        设 class_def 为 class_def 加 "(" 加 parent_name 加 ")"。
      结束。
      设 class_def 为 class_def 加 ":\n" 加 body。
      返回 列表创建(class_def, end_p)。
    结束。
  结束。
  返回 列表创建("", p)。
结束。

段 compile_class_body 接收 toks, p, end_p, class_name：
  设 out 为 ""。
  当 p 小于 end_p 且 p 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, p)。
    设 tv 为 列表获取(tok, 1)。
    设 已处理 为 假。
    如果 tv 等于 "属性"：
      设 np 为 p 加 1。
      如果 np 小于 列表长度(toks)：
        设 p 为 np 加 1。
        设 已处理 为 真。
      结束。
    结束。
    如果 已处理 等于 假 且 是函数关键字(tv)：
      设 func结果 为 compile_class_method(toks, p, class_name)。
      设 method_code 为 列表获取(func结果, 0)。
      设 p 为 列表获取(func结果, 1)。
      设 out 为 out 加 method_code。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假 且 tv 等于 "结束"：
      返回 out。
    结束。
    如果 已处理 等于 假：
      设 p 为 p 加 1。
    结束。
  结束。
  返回 out。
结束。

段 compile_class_method 接收 toks, p, class_name：
  设 tok 为 列表获取(toks, p)。
  设 np 为 p 加 1。
  设 name 为 ""。
  如果 np 小于 列表长度(toks)：
    设 name_tok 为 列表获取(toks, np)。
    设 name 为 列表获取(name_tok, 1)。
    设 np 为 np 加 1。
  结束。
  设 参数结果 为 解析参数(toks, np)。
  设 params 为 列表获取(参数结果, 0)。
  设 np 为 列表获取(参数结果, 1)。
  设 final_params 为 ""。
  如果 params 等于 "己"：
    设 final_params 为 "self"。
  结束。
  如果 params 不等于 "己" 且 字符串长度(params) 大于等于 2：
    设 前两字 为 截取(params, 0, 2)。
    如果 前两字 等于 "己,"：
      设 final_params 为 "self" 加 截取(params, 1, 字符串长度(params))。
    结束。
  结束。
  如果 final_params 等于 ""：
    设 final_params 为 "self"。
    如果 params 不等于 ""：
      设 final_params 为 "self, " 加 params。
    结束。
  结束。
  设 method_end 为 find_matching_end(toks, np, 1)。
  设 body 为 compile_block(toks, np, method_end 减 1, "        ", "")。
  如果 body 等于 ""：
    设 body 为 "        pass"。
  结束。
  设 code 为 "    def " 加 name 加 "(" 加 final_params 加 "):\n" 加 body 加 "\n"。
  返回 列表创建(code, method_end)。
结束。

段 compile_top 接收 toks, p, out：
  当 p 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, p)。
    设 tv 为 列表获取(tok, 1)。
    设 已处理 为 假。
    如果 tv 等于 "类"：
      设 结果 为 compile_class(toks, p)。
      设 class_code 为 列表获取(结果, 0)。
      设 np 为 列表获取(结果, 1)。
      设 out 为 out 加 class_code 加 "\n"。
      设 p 为 np。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假 且 是函数关键字(tv)：
      设 结果 为 compile_single_func(toks, p)。
      设 func_code 为 列表获取(结果, 0)。
      设 np 为 列表获取(结果, 1)。
      设 out 为 out 加 func_code。
      设 p 为 np。
      设 已处理 为 真。
    结束。
    如果 已处理 等于 假：
      设 p 为 p 加 1。
    结束。
  结束。
  返回 out。
结束。

段 compile_single_func 接收 toks, p：
  设 tok 为 列表获取(toks, p)。
  设 np 为 p 加 1。
  设 name 为 ""。
  如果 np 小于 列表长度(toks)：
    设 tok 为 列表获取(toks, np)。
    如果 列表获取(tok, 0) 等于 "ID"：
      设 name 为 列表获取(tok, 1)。
      设 np 为 np 加 1。
    结束。
  结束。
  设 参数结果 为 解析参数(toks, np)。
  设 params 为 列表获取(参数结果, 0)。
  设 np 为 列表获取(参数结果, 1)。
  设 body结果 为 compile_stmts(toks, np, "")。
  设 body 为 列表获取(body结果, 0)。
  设 np 为 列表获取(body结果, 1)。
  如果 body 等于 ""：
    设 body 为 "    pass\n"。
  结束。
  设 code 为 "def " 加 name 加 "(" 加 params 加 "):\n" 加 body 加 "\n"。
  返回 列表创建(code, np)。
结束。

段 压缩代码 接收 src：
  设 n 为 字符串长度(src)。
  设 out 为 ""。
  设 p 为 0。
  设 行缓冲 为 ""。
  设 换行计数 为 0。
  当 p 小于 n：
    设 c 为 字符串获取(src, p)。
    如果 c 等于 "\n"：
      设 修剪后 为 ""。
      设 i 为 字符串长度(行缓冲) 减 1。
      设 继续循环 为 真。
      当 继续循环 且 i 大于等于 0：
        设 ch 为 字符串获取(行缓冲, i)。
        如果 ch 不等于 " " 且 ch 不等于 "\t"：
          设 修剪后 为 截取(行缓冲, 0, i 加 1)。
          设 继续循环 为 假。
        否则：
          设 i 为 i 减 1。
        结束。
      结束。
      如果 修剪后 等于 ""：
        设 换行计数 为 换行计数 加 1。
        如果 换行计数 小于等于 1：
          设 out 为 out 加 "\n"。
        结束。
      否则：
        设 换行计数 为 0。
        设 out 为 out 加 修剪后 加 "\n"。
      结束。
      设 行缓冲 为 ""。
    否则：
      设 行缓冲 为 行缓冲 加 c。
    结束。
    设 p 为 p 加 1。
  结束。
  如果 行缓冲 不等于 ""：
    设 out 为 out 加 行缓冲。
  结束。
  返回 out。
结束。

段 编译 接收 src：
  设 header 为 "# Generated by Duan Level 4\n"。
  设 toks 为 词法(src)。
  设 code 为 compile_top(toks, 0, "")。
  设 result 为 header 加 code。
  返回 压缩代码(result)。
结束。

段 测试：
  打印 "=== Level 4 测试 ==="。
  打印 ""。

  打印 "--- 测试1: 基本函数 ---"。
  设 src1 为 "段落 foo 返回 42 结束"。
  打印 "源: " 加 src1。
  打印 编译(src1)。
  打印 ""。

  打印 "--- 测试2: 带变量 ---"。
  设 src2 为 "段落 bar 设 x 为 10 返回 x 结束"。
  打印 "源: " 加 src2。
  打印 编译(src2)。
  打印 ""。

  打印 "--- 测试3: 带if ---"。
  设 src3 为 "段落 baz 如果 真 返回 1 结束 返回 0 结束"。
  打印 "源: " 加 src3。
  打印 编译(src3)。
  打印 ""。

  打印 "Level 4 验证通过！"。
结束。

段 主函数：
  打印 "段言 Level 4 启动"。
  打印 ""。
  测试()。
结束。

主函数()
