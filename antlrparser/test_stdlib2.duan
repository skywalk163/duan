# 段言测试程序 - 完整标准库测试

《主段》段():
  打印("=== 数学函数测试 ===")。
  
  # 测试 sqrt
  定义root等于sqrt(16)。
  打印("sqrt(16): ")。
  打印(root)。
  
  # 测试 pow
  定义power等于pow(2, 10)。
  打印("pow(2,10): ")。
  打印(power)。
  
  # 测试 abs - 使用正确的负数表示
  定义neg等于0减42。
  定义absolute等于abs(neg)。
  打印("abs(-42): ")。
  打印(absolute)。
  
  打印("")。
  打印("=== 列表操作测试 ===")。
  
  # 创建列表
  定义arr等于【10, 20, 30, 40, 50】。
  
  # 测试长度
  定义len等于arr之长度。
  打印("列表长度: ")。
  打印(len)。
  
  # 测试索引
  定义first等于arr[0]。
  打印("第一个元素: ")。
  打印(first)。
  
  # 测试循环
  定义sum等于0。
  定义i等于0。
  当i小于len：
    sum等于sum加arr[i]。
    i等于i加1。
  结束。
  打印("元素总和: ")。
  打印(sum)。
  
  打印("")。
  打印("=== 测试完成 ===")。
结束。