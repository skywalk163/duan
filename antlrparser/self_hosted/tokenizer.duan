# 段言自举分词器
# 
# 这是第一个用段言本身编写的段言程序。
# 功能：将段言源代码分拆为 Token 列表。

# =============================================================================
# 工具函数：判断字符串是否为关键字
# =============================================================================

《是关键字》段(文本, 关键字表):
  # 遍历所有键检查是否存在
  定义所有键等于关键字表之键列。
  遍历_键 所有键：
    如果_键等于文本那么：
      返回真。
    结束。
  结束。
  返回假。
结束。

《取关键字类型》段(文本, 关键字表):
  # 直接取类型（调用方已确保键存在）
  返回关键字表[文本]。
结束。

# =============================================================================
# 工具函数：判断字符串是否为符号
# =============================================================================

《是符号》段(文本, 符号表):
  定义所有键等于符号表之键列。
  遍历_键 所有键：
    如果_键等于文本那么：
      返回真。
    结束。
  结束。
  返回假。
结束。

《取符号类型》段(文本, 符号表):
  返回符号表[文本]。
结束。

# =============================================================================
# 关键字表
# =============================================================================

《构建关键字表》段():
  返回_典(
    # 条件判断
    "否则若", "K_ELSE_IF",
    "如果", "K_IF",
    "那么", "K_THEN",
    "否则", "K_ELSE",
    "结束", "K_END",
    # 比较
    "大于等于", "K_GE",
    "小于等于", "K_LE",
    "不等于", "K_NE",
    "大于", "K_GT",
    "小于", "K_LT",
    # 定义声明
    "定义", "K_DEFINE",
    "等于", "K_EQUAL",
    "段", "K_SEGMENT",
    "导出", "K_EXPORT",
    "导入", "K_IMPORT",
    "从", "K_FROM",
    # 循环控制
    "遍历", "K_FOREACH",
    "当", "K_WHILE",
    "跳出", "K_BREAK",
    "跳过", "K_CONTINUE",
    # 异常处理
    "尝试", "K_TRY",
    "捕获", "K_CATCH",
    "抛出", "K_THROW",
    # 返回
    "返回", "K_RETURN",
    # 数据操作
    "打印", "K_PRINT",
    "输出", "K_OUTPUT",
    # 逻辑运算
    "且", "K_AND",
    "或", "K_OR",
    "非", "K_NOT",
    # 算术运算
    "加", "K_PLUS",
    "减", "K_MINUS",
    "乘", "K_MULTIPLY",
    "除", "K_DIVIDE",
    "模", "K_MOD",
    "幂", "K_POW",
    # 连接符/属性
    "并", "K_AND_WORD",
    "之", "K_OF",
    "的", "K_DE",
    # 特殊值
    "真", "K_TRUE",
    "假", "K_FALSE",
    "空", "K_NULL",
    # 内置类型
    "整数", "T_INT",
    "浮数", "T_FLOAT",
    "数", "T_NUMBER",
    "串", "T_STRING",
    "列", "T_LIST",
    "典", "T_DICT",
    "布尔", "T_BOOL"
  )。
结束。

# =============================================================================
# 符号表
# =============================================================================

《构建符号表》段():
  返回_典(
    "。", "DOT", ".", "DOT",
    "，", "COMMA", ",", "COMMA",
    "：", "COLON", ":", "COLON",
    "；", "SEMICOLON", ";", "SEMICOLON",
    "、", "PAUSE",
    "（", "LPAREN", "(", "LPAREN",
    "）", "RPAREN", ")", "RPAREN",
    "【", "LBRACKET", "[", "LBRACKET",
    "】", "RBRACKET", "]", "RBRACKET",
    "{", "LBRACE", "}", "RBRACE",
    "《", "BOOK_L", "》", "BOOK_R",
    "＼", "PATH_SEP", "/", "PATH_SEP",
    "^", "POW", "%", "MODULO",
    "*", "MULTIPLY", "×", "MULTIPLY",
    "÷", "DIVIDE",
    "+", "PLUS",
    ">", "GT",
    "<", "LT",
    "!", "NOT",
    "-", "MINUS",
    "=", "ASSIGN",
    "~", "TILDE",
    "|", "PIPE_CHAR",
    "&", "AMPERSAND"
  )。
结束。

# =============================================================================
# 多字符符号表
# =============================================================================

《构建多字符符号表》段():
  返回_典(
    "->", "PIPE",
    "==", "EQ",
    "!=", "NE",
    ">=", "GE",
    "<=", "LE",
    "&&", "AND",
    "||", "OR"
  )。
结束。

# =============================================================================
# 复合词安全单字关键词集
# =============================================================================

《构建复合安全集》段():
  返回_典(
    "数", 真, "列", 真, "串", 真, "典", 真,
    "从", 真, "段", 真,
    "空", 真, "真", 真, "假", 真,
    "父", 真
  )。
结束。

# =============================================================================
# 创建 Token
# =============================================================================

《创建_Token》段(种类, 文本, 行号, 列号):
  返回_典("type", 种类, "text", 文本, "line", 行号, "col", 列号)。
结束。

# =============================================================================
# 主分词器
# =============================================================================

《分词器》段(源码):
  # 加载查找表
  定义关键字等于《构建关键字表》()。
  定义符号等于《构建符号表》()。
  定义多字符符号等于《构建多字符符号表》()。
  定义复合安全等于《构建复合安全集》()。
  
  # 初始化状态
  定义结果等于【】。
  定义行号等于0。
  定义列号等于0。
  定义位置等于0。
  定义长度等于源码之长度。
  
  当位置小于长度：
    # 安全边界检查
    如果位置大于等于长度那么：
      跳出。
    结束。
    定义字符等于源码[位置]。
    
    # ---- 空白字符 ----
    如果字符等于" "或字符等于"\t"或字符等于"\r"或字符等于"\n"那么：
      如果字符等于"\n"那么：
        行号等于行号加1。
        列号等于0。
      否则：
        列号等于列号加1。
      结束。
      位置等于位置加1。
      跳过。
    结束。
    
    # ---- 单行注释 ---- 
    如果字符等于"#"那么：
      当位置小于长度且源码[位置]不等于"\n"：
        位置等于位置加1。
      结束。
      跳过。
    结束。
    
    # ---- 块注释 ```...``` ----
    如果位置加2小于长度且源码[位置]等于"`"且源码[位置加1]等于"`"且源码[位置加2]等于"`"那么：
      位置等于位置加3。
      列号等于列号加3。
      当位置小于长度且源码[位置]不等于"\n"：
        位置等于位置加1。
      结束。
      如果位置小于长度且源码[位置]等于"\n"那么：
        行号等于行号加1。
        列号等于0。
        位置等于位置加1。
      结束。
      定义找到等于假。
      当位置小于长度且找到等于假：
        如果位置加2小于长度且源码[位置]等于"`"且源码[位置加1]等于"`"且源码[位置加2]等于"`"那么：
          位置等于位置加3。
          列号等于列号加3。
          找到等于真。
        否则：
          如果源码[位置]等于"\n"那么：
            行号等于行号加1。
            列号等于0。
          否则：
            列号等于列号加1。
          结束。
          位置等于位置加1。
        结束。
      结束。
      跳过。
    结束。
    
    # ---- 多字符符号 ----
    如果位置加1小于长度那么：
      定义文本2等于源码[位置]加源码[位置加1]。
      如果《是关键字》(文本2, 多字符符号)那么：
        定义种类2等于《取关键字类型》(文本2, 多字符符号)。
        结果等于结果加【《创建_Token》(种类2, 文本2, 行号, 列号)】。
        位置等于位置加2。
        列号等于列号加2。
        跳过。
      结束。
    结束。
    
    # ---- 中英文标点和单字符符号 ----
    如果《是关键字》(字符, 符号)那么：
      定义种类等于《取关键字类型》(字符, 符号)。
      结果等于结果加【《创建_Token》(种类, 字符, 行号, 列号)】。
      位置等于位置加1。
      列号等于列号加1。
      跳过。
    结束。
    
    # ---- 字符串（" 和 '） ----
    如果字符等于"\""或字符等于"'"那么：
      定义引号等于字符。
      定义起始行等于行号。
      定义起始列等于列号。
      定义字符文本等于字符。
      位置等于位置加1。
      列号等于列号加1。
      当位置小于长度且源码[位置]不等于引号：
        如果源码[位置]等于"\\"那么：
          字符文本等于字符文本加"\\"。
          位置等于位置加1。
          列号等于列号加1。
          如果位置小于长度那么：
            字符文本等于字符文本加源码[位置]。
            位置等于位置加1。
            列号等于列号加1。
          结束。
        否则：
          如果源码[位置]等于"\n"那么：
            行号等于行号加1。
            列号等于0。
          否则：
            列号等于列号加1。
          结束。
          字符文本等于字符文本加源码[位置]。
          位置等于位置加1。
        结束。
      结束。
      如果位置小于长度那么：
        字符文本等于字符文本加源码[位置]。
        位置等于位置加1。
        列号等于列号加1。
      结束。
      结果等于结果加【《创建_Token》("STRING", 字符文本, 起始行, 起始列)】。
      跳过。
    结束。
    
    # ---- 关键字/标识符 ----
    如果_是中文(字符)或_是字母(字符)那么：
      定义起始行等于行号。
      定义起始列等于列号。
      
      # 先尝试匹配中文关键字
      定义关键字匹配等于假。
      
      如果_是中文(字符)那么：
        # 从长到短尝试匹配关键字（最长3字）
        定义kw_len等于3。
        当kw_len大于等于1且关键字匹配等于假：
          如果位置加kw_len小于等于长度那么：
            定义kw_文本等于""。
            定义kwi等于0。
            当kwi小于kw_len：
              kw_文本等于kw_文本加源码[位置加kwi]。
              kwi等于kwi加1。
            结束。
            # 检查是否是关键字
            如果《是关键字》(kw_文本, 关键字)那么：
              # 单字复合词安全检查
              如果kw_len等于1且《是关键字》(kw_文本, 复合安全)且位置加1小于长度且_是中文(源码[位置加1])那么：
                关键字匹配等于假。
              否则：
                关键字匹配等于真。
                定义种类等于《取关键字类型》(kw_文本, 关键字)。
                结果等于结果加【《创建_Token》(种类, kw_文本, 起始行, 起始列)】。
                位置等于位置加kw_len。
                列号等于列号加kw_len。
              结束。
            结束。
          结束。
          kw_len等于kw_len减1。
        结束。
      结束。
      
      如果关键字匹配那么：
        跳过。
      结束。
      
      # 不是关键字，收集标识符
      定义id文本等于""。
      定义id行等于行号。
      定义id列等于列号。
      
      当位置小于长度：
        定义c等于源码[位置]。
        
        如果_是中文(c)那么：
          # 检查是否是关键词开头
          定义是kw开头等于假。
          定义kw_len2等于3。
          当kw_len2大于等于1且是kw开头等于假：
            如果位置加kw_len2小于等于长度那么：
              定义kwt等于""。
              定义kwi2等于0。
              当kwi2小于kw_len2：
                kwt等于kwt加源码[位置加kwi2]。
                kwi2等于kwi2加1。
              结束。
              如果《是关键字》(kwt, 关键字)那么：
                如果kw_len2等于1且《是关键字》(kwt, 复合安全)那么：
                  是kw开头等于假。
                否则：
                  是kw开头等于真。
                结束。
              结束。
            结束。
            kw_len2等于kw_len2减1。
          结束。
          
          如果是kw开头那么：
            跳出。
          结束。
          id文本等于id文本加c。
          位置等于位置加1。
          列号等于列号加1。
        否则若_是字母(c)或_是数字(c)那么：
          id文本等于id文本加c。
          位置等于位置加1。
          列号等于列号加1。
        否则：
          跳出。
        结束。
      结束。
      
      如果id文本不等于""那么：
        如果《是关键字》(id文本, 关键字)那么：
          定义k种类等于《取关键字类型》(id文本, 关键字)。
          结果等于结果加【《创建_Token》(k种类, id文本, id行, id列)】。
        否则：
          结果等于结果加【《创建_Token》("ID", id文本, id行, id列)】。
        结束。
      结束。
      跳过。
    结束。
    
    # ---- 数字 ----
    如果_是数字(字符)那么：
      定义起始行等于行号。
      定义起始列等于列号。
      定义数文本等于""。
      当位置小于长度且_是数字(源码[位置])：
        数文本等于数文本加源码[位置]。
        位置等于位置加1。
        列号等于列号加1。
      结束。
      # 检查小数点（后跟数字）
      如果位置小于长度且源码[位置]等于"."且位置加1小于长度且_是数字(源码[位置加1])那么：
        数文本等于数文本加"."。
        位置等于位置加1。
        列号等于列号加1。
        当位置小于长度且_是数字(源码[位置])：
          数文本等于数文本加源码[位置]。
          位置等于位置加1。
          列号等于列号加1。
        结束。
      结束。
      结果等于结果加【《创建_Token》("NUMBER", 数文本, 起始行, 起始列)】。
      跳过。
    结束。
    
    # ---- 无法识别的字符 ----
    位置等于位置加1。
    列号等于列号加1。
  结束。
  
  返回结果。
结束。