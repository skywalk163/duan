# 段言标准库
# 提供常用的数学函数和字符串处理功能

# ========== 数学函数 ==========

《_abs》段(_n):
  如果_n小于0那么：
    返回0减_n。
  结束。
  返回_n。
结束。

《_sqrt》段(_n):
  如果_n小于0那么：
    打印("错误：平方根参数不能为负数")。
    返回空。
  结束。
  _guess等于_n除2。
  当《_abs》(_guess乘_guess减_n)大于0.0001：
    _guess等于(_guess加_n除_guess)除2。
  结束。
  返回_guess。
结束。

《_pow》段(_base, _exp):
  如果_exp等于0那么：
    返回1。
  结束。
  如果_exp小于0那么：
    返回1除《_pow》(_base, 0减_exp)。
  结束。
  _result等于1。
  _i等于0。
  当_i小于_exp：
    _result等于_result乘_base。
    _i等于_i加1。
  结束。
  返回_result。
结束。

《_max》段(_a, _b):
  如果_a大于_b那么：
    返回_a。
  结束。
  返回_b。
结束。

《_min》段(_a, _b):
  如果_a小于_b那么：
    返回_a。
  结束。
  返回_b。
结束。

《_round》段(_n):
  _intPart等于_n除1减(_n除1除1乘1减(_n除1除1乘1)除1乘1)。
  _fracPart等于_n减_intPart。
  如果_fracPart大于等于0.5那么：
    返回_intPart加1。
  结束。
  返回_intPart。
结束。

《_floor》段(_n):
  _intPart等于_n除1减(_n除1除1乘1减(_n除1除1乘1)除1乘1)。
  如果_n小于0那么：
    如果_n不等于_intPart那么：
      返回_intPart减1。
    结束。
  结束。
  返回_intPart。
结束。

《_ceil》段(_n):
  _intPart等于_n除1减(_n除1除1乘1减(_n除1除1乘1)除1乘1)。
  如果_n大于0那么：
    如果_n不等于_intPart那么：
      返回_intPart加1。
    结束。
  结束。
  返回_intPart。
结束。

《_sin》段(_x):
  _result等于0。
  _term等于_x。
  _sign等于1。
  _fact等于1。
  _i等于1。
  
  当《_abs》(_term)大于0.000001：
    _result等于_result加_sign乘_term。
    _sign等于0减_sign。
    _fact等于_fact乘(_i加1)乘(_i加2)。
    _term等于_term乘_x乘_x除_fact。
    _i等于_i加2。
  结束。
  
  返回_result。
结束。

《_cos》段(_x):
  _result等于1。
  _term等于1。
  _sign等于1。
  _fact等于1。
  _i等于0。
  
  当《_abs》(_term)大于0.000001：
    如果_i大于0那么：
      _result等于_result加_sign乘_term。
    结束。
    _sign等于0减_sign。
    _fact等于_fact乘(_i加1)乘(_i加2)。
    _term等于_term乘_x乘_x除_fact。
    _i等于_i加2。
  结束。
  
  返回_result。
结束。

《_tan》段(_x):
  如果《_abs》(《_cos》(_x))小于0.000001那么：
    打印("错误：tan 参数无效")。
    返回空。
  结束。
  返回《_sin》(_x)除《_cos》(_x)。
结束。

《_exp》段(_x):
  _result等于1。
  _term等于1。
  _i等于1。
  
  当《_abs》(_term)大于0.000001：
    _term等于_term乘_x除_i。
    _result等于_result加_term。
    _i等于_i加1。
  结束。
  
  返回_result。
结束。

《_log》段(_x):
  如果_x小于等于0那么：
    打印("错误：log 参数必须大于0")。
    返回空。
  结束。
  
  _n等于_x减1。
  _result等于0。
  _term等于_n。
  _sign等于1。
  _i等于1。
  
  当《_abs》(_term)大于0.000001：
    _result等于_result加_sign乘_term除_i。
    _sign等于0减_sign。
    _term等于_term乘_n。
    _i等于_i加1。
  结束。
  
  返回_result。
结束。

《_log10》段(_x):
  _ln10等于2.302585093。
  返回《_log》(_x)除_ln10。
结束。

《_pow》段(_base, _exp):
  如果_exp等于0那么：
    返回1。
  结束。
  如果_exp小于0那么：
    返回1除《_pow》(_base, 0减_exp)。
  结束。
  
  _intPart等于_exp除1减(_exp除1除1乘1减(_exp除1除1乘1)除1乘1)。
  _fracPart等于_exp减_intPart。
  
  _intResult等于1。
  _tempBase等于_base。
  _tempExp等于_intPart。
  
  当_tempExp大于0：
    如果_tempExp除2乘2不等于_tempExp那么：
      _intResult等于_intResult乘_tempBase。
    结束。
    _tempBase等于_tempBase乘_tempBase。
    _tempExp等于《_floor》(_tempExp除2)。
  结束。
  
  如果_fracPart不等于0那么：
    _fracResult等于《_exp》(_fracPart乘《_log》(_base))。
    返回_intResult乘_fracResult。
  结束。
  
  返回_intResult。
结束。

《_sqrt》段(_n):
  如果_n小于0那么：
    打印("错误：平方根参数不能为负数")。
    返回空。
  结束。
  如果_n等于0那么：
    返回0。
  结束。
  
  _guess等于_n除2。
  当《_abs》(_guess乘_guess减_n)大于0.000001：
    _guess等于(_guess加_n除_guess)除2。
  结束。
  返回_guess。
结束。

《_cbrt》段(_n):
  如果_n等于0那么：
    返回0。
  结束。
  
  _sign等于1。
  如果_n小于0那么：
    _sign等于0减1。
    _n等于0减_n。
  结束。
  
  _guess等于_n除3。
  当《_abs》(_guess乘_guess乘_guess减_n)大于0.000001：
    _guess等于((2乘_guess)加_n除(_guess乘_guess))除3。
  结束。
  
  返回_sign乘_guess。
结束。

《_mod》段(_a, _b):
  如果_b等于0那么：
    打印("错误：模运算除数不能为0")。
    返回空。
  结束。
  
  _result等于_a减_b乘《_floor》(_a除_b)。
  返回_result。
结束。

# ========== 字符串函数 ==========

《_len》段(_s):
  返回_s之长度。
结束。

《_substring》段(_s, _start, _end):
  _result等于""。
  _i等于_start。
  当_i小于_end：
    当_i小于_s之长度：
      _result等于_result加_s[_i]。
    结束。
    _i等于_i加1。
  结束。
  返回_result。
结束。

《_indexOf》段(_s, _sub):
  _len等于_s之长度。
  _subLen等于_sub之长度。
  如果_subLen等于0那么：
    返回0。
  结束。
  _i等于0。
  当_i小于等于_len减_subLen：
    _j等于0。
    _match等于真。
    当_j小于_subLen：
      如果_s[_i加_j]不等于_sub[_j]那么：
        _match等于假。
        _j等于_subLen。
      结束。
      _j等于_j加1。
    结束。
    如果_match等于真那么：
      返回_i。
    结束。
    _i等于_i加1。
  结束。
  返回0减1。
结束。

《_trim》段(_s):
  _start等于0。
  当_start小于_s之长度：
    如果_s[_start]等于" "那么：
      _start等于_start加1。
    否则：
      _start等于_s之长度。
    结束。
  结束。
  
  _end等于_s之长度。
  当_end大于_start：
    如果_s[_end减1]等于" "那么：
      _end等于_end减1。
    否则：
      _end等于_start。
    结束。
  结束。
  
  返回《_substring》(_s, _start, _end)。
结束。

《_split》段(_s, _delimiter):
  _result等于_列()。
  _current等于""。
  _i等于0。
  _delLen等于_delimiter之长度。
  
  如果_delLen等于0那么：
    _result添加(_s)。
    返回_result。
  结束。
  
  当_i小于_s之长度：
    _match等于真。
    _j等于0。
    当_j小于_delLen：
      如果_i加_j大于等于_s之长度那么：
        _match等于假。
        _j等于_delLen。
      否则：
        如果_s[_i加_j]不等于_delimiter[_j]那么：
          _match等于假。
          _j等于_delLen。
        结束。
      结束。
      _j等于_j加1。
    结束。
    
    如果_match等于真那么：
      _result添加(_current)。
      _current等于""。
      _i等于_i加_delLen。
    否则：
      _current等于_current加_s[_i]。
      _i等于_i加1。
    结束。
  结束。
  
  如果_current不等于""那么：
    _result添加(_current)。
  结束。
  
  返回_result。
结束。

《_join》段(_list, _separator):
  _result等于""。
  _i等于0。
  遍历_item _list：
    如果_i大于0那么：
      _result等于_result加_separator。
    结束。
    _result等于_result加_item。
    _i等于_i加1。
  结束。
  返回_result。
结束。

《_replace》段(_s, _old, _new):
  _result等于""。
  _oldLen等于_old之长度。
  _sLen等于_s之长度。
  
  如果_oldLen等于0那么：
    返回_s。
  结束。
  
  _i等于0。
  当_i小于_sLen：
    _match等于真。
    如果_i加_oldLen小于等于_sLen那么：
      _j等于0。
      当_j小于_oldLen：
        如果_s[_i加_j]不等于_old[_j]那么：
          _match等于假。
          _j等于_oldLen。
        结束。
        _j等于_j加1。
      结束。
    否则：
      _match等于假。
    结束。
    
    如果_match等于真那么：
      _result等于_result加_new。
      _i等于_i加_oldLen。
    否则：
      _result等于_result加_s[_i]。
      _i等于_i加1。
    结束。
  结束。
  
  返回_result。
结束。

《_startsWith》段(_s, _prefix):
  _prefixLen等于_prefix之长度。
  _sLen等于_s之长度。
  
  如果_prefixLen大于_sLen那么：
    返回假。
  结束。
  
  _i等于0。
  当_i小于_prefixLen：
    如果_s[_i]不等于_prefix[_i]那么：
      返回假。
    结束。
    _i等于_i加1。
  结束。
  
  返回真。
结束。

《_endsWith》段(_s, _suffix):
  _suffixLen等于_suffix之长度。
  _sLen等于_s之长度。
  
  如果_suffixLen大于_sLen那么：
    返回假。
  结束。
  
  _start等于_sLen减_suffixLen。
  _i等于0。
  当_i小于_suffixLen：
    如果_s[_start加_i]不等于_suffix[_i]那么：
      返回假。
    结束。
    _i等于_i加1。
  结束。
  
  返回真。
结束。

《_toLowerCase》段(_s):
  _result等于""。
  _i等于0。
  当_i小于_s之长度：
    _c等于_s[_i]。
    如果_c大于等于"A"那么：
      如果_c小于等于"Z"那么：
        _result等于_result加《_charCode》(_c)加32之字符。
      否则：
        _result等于_result加_c。
      结束。
    否则：
      _result等于_result加_c。
    结束。
    _i等于_i加1。
  结束。
  返回_result。
结束。

《_toUpperCase》段(_s):
  _result等于""。
  _i等于0。
  当_i小于_s之长度：
    _c等于_s[_i]。
    如果_c大于等于"a"那么：
      如果_c小于等于"z"那么：
        _result等于_result加《_charCode》(_c)减32之字符。
      否则：
        _result等于_result加_c。
      结束。
    否则：
      _result等于_result加_c。
    结束。
    _i等于_i加1。
  结束。
  返回_result。
结束。

《_charCode》段(_c):
  _code等于0。
  _i等于0。
  当_i小于_c之长度：
    _code等于(_code乘256)加_c[_i]之码值。
    _i等于_i加1。
  结束。
  返回_code。
结束。

《_repeat》段(_s, _count):
  _result等于""。
  _i等于0。
  当_i小于_count：
    _result等于_result加_s。
    _i等于_i加1。
  结束。
  返回_result。
结束。

《_padStart》段(_s, _length, _padStr):
  _sLen等于_s之长度。
  如果_sLen大于等于_length那么：
    返回_s。
  结束。
  
  _padLen等于_length减_sLen。
  _padStrLen等于_padStr之长度。
  如果_padStrLen等于0那么：
    _padStr等于" "。
    _padStrLen等于1。
  结束。
  
  _result等于""。
  _i等于0。
  当_i小于_padLen：
    _idx等于_i除_padStrLen乘_padStrLen。
    如果_idx不等于_i那么：
      _idx等于_i除_padStrLen乘_padStrLen。
    结束。
    _result等于_result加_padStr[_idx]。
    _i等于_i加1。
  结束。
  
  返回_result加_s。
结束。

《_padEnd》段(_s, _length, _padStr):
  _sLen等于_s之长度。
  如果_sLen大于等于_length那么：
    返回_s。
  结束。
  
  _padLen等于_length减_sLen。
  _padStrLen等于_padStr之长度。
  如果_padStrLen等于0那么：
    _padStr等于" "。
    _padStrLen等于1。
  结束。
  
  _result等于_s。
  _i等于0。
  当_i小于_padLen：
    _idx等于_i除_padStrLen乘_padStrLen。
    如果_idx不等于_i那么：
      _idx等于_i除_padStrLen乘_padStrLen。
    结束。
    _result等于_result加_padStr[_idx]。
    _i等于_i加1。
  结束。
  
  返回_result。
结束。

# ========== 列表函数 ==========

《_listLen》段(_list):
  返回_list之长度。
结束。

《_listAppend》段(_list, _item):
  _list添加(_item)。
  返回_list。
结束。

《_listIndexOf》段(_list, _item):
  _i等于0。
  遍历_val _list：
    如果_val等于_item那么：
      返回_i。
    结束。
    _i等于_i加1。
  结束。
  返回0减1。
结束。

《_listReverse》段(_list):
  _len等于_list之长度。
  _i等于0。
  当_i小于_len除2：
    _temp等于_list[_i]。
    _list[_i]等于_list[_len减_i减1]。
    _list[_len减_i减1]等于_temp。
    _i等于_i加1。
  结束。
  返回_list。
结束。

《_listInsert》段(_list, _index, _item):
  _len等于_list之长度。
  如果_index小于0那么：
    _index等于0。
  结束。
  如果_index大于_len那么：
    _index等于_len。
  结束。
  
  _i等于_len减1。
  当_i大于等于_index：
    _list[_i加1]等于_list[_i]。
    _i等于_i减1。
  结束。
  
  _list[_index]等于_item。
  返回_list。
结束。

《_listRemove》段(_list, _index):
  _len等于_list之长度。
  如果_index小于0或者_index大于等于_len那么：
    返回空。
  结束。
  
  _result等于_list[_index]。
  _i等于_index。
  当_i小于_len减1：
    _list[_i]等于_list[_i加1]。
    _i等于_i加1。
  结束。
  
  _list移除(空)。
  返回_result。
结束。

《_listSlice》段(_list, _start, _end):
  _len等于_list之长度。
  _result等于_列()。
  
  如果_start小于0那么：
    _start等于0。
  结束。
  如果_end大于_len那么：
    _end等于_len。
  结束。
  如果_start大于_end那么：
    _temp等于_start。
    _start等于_end。
    _end等于_temp。
  结束。
  
  _i等于_start。
  当_i小于_end：
    _result添加(_list[_i])。
    _i等于_i加1。
  结束。
  
  返回_result。
结束。

《_listConcat》段(_list1, _list2):
  _result等于_列()。
  遍历_item _list1：
    _result添加(_item)。
  结束。
  遍历_item _list2：
    _result添加(_item)。
  结束。
  返回_result。
结束。

《_listIndexOf》段(_list, _item):
  _i等于0。
  遍历_val _list：
    如果_val等于_item那么：
      返回_i。
    结束。
    _i等于_i加1。
  结束。
  返回0减1。
结束。

《_listContains》段(_list, _item):
  遍历_val _list：
    如果_val等于_item那么：
      返回真。
    结束。
  结束。
  返回假。
结束。

《_listCopy》段(_list):
  _result等于_列()。
  遍历_item _list：
    _result添加(_item)。
  结束。
  返回_result。
结束。

《_listSort》段(_list):
  _len等于_list之长度。
  _i等于0。
  当_i小于_len减1：
    _j等于0。
    当_j小于_len减_i减1：
      如果_list[_j]大于_list[_j加1]那么：
        _temp等于_list[_j]。
        _list[_j]等于_list[_j加1]。
        _list[_j加1]等于_temp。
      结束。
      _j等于_j加1。
    结束。
    _i等于_i加1。
  结束。
  返回_list。
结束。

# ========== 调试函数 ==========

《_printDebug》段(_msg, _value):
  打印("DEBUG: "加_msg加" = "加_value)。
结束。

《_assert》段(_condition, _msg):
  如果_condition不等于真那么：
    打印("断言失败: "加_msg)。
    打印("程序终止")。
    返回。
  结束。
结束。

# ========== 类型检查函数 ==========

《_isNull》段(_val):
  返回_val等于空。
结束。

# ========== 初始化标准库到全局环境 ==========

《_initStdLib》段(_env):
  # 数学函数
  《_setMapValue》(_env["current"], "abs", 《_abs》)。
  《_setMapValue》(_env["current"], "floor", 《_floor》)。
  《_setMapValue》(_env["current"], "ceil", 《_ceil》)。
  《_setMapValue》(_env["current"], "round", 《_round》)。
  《_setMapValue》(_env["current"], "sqrt", 《_sqrt》)。
  《_setMapValue》(_env["current"], "cbrt", 《_cbrt》)。
  《_setMapValue》(_env["current"], "pow", 《_pow》)。
  《_setMapValue》(_env["current"], "mod", 《_mod》)。
  《_setMapValue》(_env["current"], "max", 《_max》)。
  《_setMapValue》(_env["current"], "min", 《_min》)。
  《_setMapValue》(_env["current"], "sin", 《_sin》)。
  《_setMapValue》(_env["current"], "cos", 《_cos》)。
  《_setMapValue》(_env["current"], "tan", 《_tan》)。
  《_setMapValue》(_env["current"], "exp", 《_exp》)。
  《_setMapValue》(_env["current"], "log", 《_log》)。
  《_setMapValue》(_env["current"], "log10", 《_log10》)。
  
  # 字符串函数
  《_setMapValue》(_env["current"], "len", 《_len》)。
  《_setMapValue》(_env["current"], "substring", 《_substring》)。
  《_setMapValue》(_env["current"], "indexOf", 《_indexOf》)。
  《_setMapValue》(_env["current"], "trim", 《_trim》)。
  《_setMapValue》(_env["current"], "split", 《_split》)。
  《_setMapValue》(_env["current"], "join", 《_join》)。
