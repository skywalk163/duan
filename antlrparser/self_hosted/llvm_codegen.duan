# 段言自举 LLVM 代码生成器
# 
# 将 AST 转换为 LLVM IR 文本，用于自举编译链。
# 配合 clang 可生成原生可执行文件。

# =============================================================================
# 辅助函数
# =============================================================================

《新寄存器》段():
  _globalCounter等于0。
  如果_globalCounter等于0那么：
    _globalCounter等于1。
  否则：
    _globalCounter等于_globalCounter加1。
  结束。
  返回"%加_globalCounter"。
结束。

《新标签》段(前缀):
  _labelCounter等于0。
  如果_labelCounter等于0那么：
    _labelCounter等于1。
  否则：
    _labelCounter等于_labelCounter加1。
  结束。
  返回前缀加_labelCounter。
结束。

《字符串转LLVM》段(文本):
  # 简单的字符串转义
  _result等于""。
  遍历_字符 文本：
    如果_字符等于"\\"那么：
      _result等于_result加"\\5C"。
    结束。
    如果_字符等于"\""那么：
      _result等于_result加"\\22"。
    结束。
    如果_字符等于"\n"那么：
      _result等于_result加"\\0A"。
    结束。
    如果_字符不等于"\\"那么：
      如果_字符不等于"\""那么：
        如果_字符不等于"\n"那么：
          _result等于_result加_字符。
        结束。
      结束。
    结束。
  结束。
  返回_result。
结束。

# =============================================================================
# 代码生成主函数
# =============================================================================

《生成模块》段(_mod):
  _code等于_列()。
  
  # 模块头
  _code添加("; 段言编译输出")。
  _code添加("target triple = \"x86_64-pc-windows-msvc\"")。
  _code添加("")。
  
  # 声明运行时函数
  _code添加("declare i32 @printf(i8*, ...)")。
  _code添加("declare i32 @puts(i8*)")。
  _code添加("")。
  
  # 字符串常量
  _code添加("@.printf_fmt = private unnamed_addr constant [4 x i8] c\"%d\\0A\\00\"")。
  _code添加("")。
  
  # 生成段落定义
  遍历_段 _mod["segments"]：
    _segCode等于《生成段落》(_段)。
    _code添加(_segCode)。
    _code添加("")。
  结束。
  
  # 生成主函数（包装顶层语句）
  如果_mod["statements"]之长度大于0那么：
    _mainCode等于《生成主函数》(_mod["statements"])。
    _code添加(_mainCode)。
  结束。
  
  返回_code连接("\n")。
结束。

# =============================================================================
# 段落生成
# =============================================================================

《生成段落》段(_seg):
  _code等于_列()。
  _name等于_seg["name"]。
  
  # 函数签名
  _code添加("define i32 @_"加_name加"(i32 %"加_name加"_args) {")。
  _code添加("  ; 参数处理（简化）")。
  
  # 生成体
  遍历_语句 _seg["body"]：
    _stmtCode等于《生成语句》(_语句)。
    如果_stmtCode不等于空那么：
      _code添加("  "加_stmtCode)。
    结束。
  结束。
  
  _code添加("  ret i32 0")。
  _code添加("}")。
  
  返回_code连接("\n")。
结束。

# =============================================================================
# 主函数生成
# =============================================================================

《生成主函数》段(_stmts):
  _code等于_列()。
  
  _code添加("define i32 @main() {")。
  
  # 分配变量
  遍历_语句 _stmts：
    如果_语句["_type"]等于"VariableDeclaration"那么：
      _name等于_语句["name"]。
      _code添加("  %"加_name加" = alloca i32, align 4")。
    结束。
  结束。
  
  # 执行语句
  遍历_语句 _stmts：
    _stmtCode等于《生成语句》(_语句)。
    如果_stmtCode不等于空那么：
      _code添加("  "加_stmtCode)。
    结束。
  结束。
  
  _code添加("  ret i32 0")。
  _code添加("}")。
  
  返回_code连接("\n")。
结束。

# =============================================================================
# 语句生成
# =============================================================================

《生成语句》段(_stmt):
  如果_stmt等于空那么：
    返回空。
  结束。

  _t等于_stmt["_type"]。

  # 变量声明
  如果_t等于"VariableDeclaration"那么：
    _name等于_stmt["name"]。
    _valCode等于《生成表达式》(_stmt["value"])。
    如果_valCode不等于空那么：
      返回"store i32 "加_valCode加", i32* %"加_name加", align 4"。
    结束。
    返回空。
  结束。

  # 赋值语句
  如果_t等于"Assignment"那么：
    _target等于_stmt["target"]。
    _valCode等于《生成表达式》(_stmt["value"])。
    
    如果_target["_type"]等于"Identifier"那么：
      _name等于_target["name"]。
      返回"store i32 "加_valCode加", i32* %"加_name加", align 4"。
    结束。
    
    返回空。
  结束。

  # 如果语句
  如果_t等于"IfStatement"那么：
    _condCode等于《生成表达式》(_stmt["condition"])。
    _label1等于《新标签》("if.then")。
    _label2等于《新标签》("if.else")。
    _label3等于《新标签》("if.end")。
    
    _code等于_列()。
    _code添加("%cmp = icmp ne i32 "加_condCode加", 0")。
    _code添加("br i1 %cmp, label %"加_label1加", label %"加_label2)。
    _code添加(_label1加":")。
    
    遍历_真语句 _stmt["then_body"]：
      _thenCode等于《生成语句》(_真语句)。
      如果_thenCode不等于空那么：
        _code添加("  "加_thenCode)。
      结束。
    结束。
    
    _code添加("  br label %"加_label3)。
    _code添加(_label2加":")。
    
    如果_stmt["else_body"]不等于空那么：
      遍历_假语句 _stmt["else_body"]：
        _elseCode等于《生成语句》(_假语句)。
        如果_elseCode不等于空那么：
          _code添加("  "加_elseCode)。
        结束。
      结束。
    结束。
    
    _code添加("  br label %"加_label3)。
    _code添加(_label3加":")。
    
    返回_code连接("\n  ")。
  结束。

  # 当循环
  如果_t等于"WhileStatement"那么：
    _condCode等于《生成表达式》(_stmt["condition"])。
    _label1等于《新标签》("while.cond")。
    _label2等于《新标签》("while.body")。
    _label3等于《新标签》("while.end")。
    
    _code等于_列()。
    _code添加("br label %"加_label1)。
    _code添加(_label1加":")。
    _code添加("  %cond = icmp ne i32 "加_condCode加", 0")。
    _code添加("  br i1 %cond, label %"加_label2加", label %"加_label3)。
    _code添加(_label2加":")。
    
    遍历_体语句 _stmt["body"]：
      _bodyCode等于《生成语句》(_体语句)。
      如果_bodyCode不等于空那么：
        _code添加("  "加_bodyCode)。
      结束。
    结束。
    
    _code添加("  br label %"加_label1)。
    _code添加(_label3加":")。
    
    返回_code连接("\n")。
  结束。

  # 打印语句
  如果_t等于"PrintStatement"那么：
    _valCode等于《生成表达式》(_stmt["value"])。
    _fmtCode等于"%fmt_ptr = getelementptr inbounds [4 x i8], [4 x i8]* @.printf_fmt, i32 0, i32 0"。
    _callCode等于"call i32 (i8*, ...) @printf(i8* %fmt_ptr, i32 "加_valCode加")"。
    返回_fmtCode加"\n  "加_callCode。
  结束。

  # 返回语句
  如果_t等于"ReturnStatement"那么：
    如果_stmt["value"]不等于空那么：
      _valCode等于《生成表达式》(_stmt["value"])。
      返回"ret i32 "加_valCode。
    结束。
    返回"ret i32 0"。
  结束。

  # 表达式语句
  如果_t等于"ExpressionStatement"那么：
    _exprCode等于《生成表达式》(_stmt["expression"])。
    如果_exprCode不等于空那么：
      # 丢弃结果
      返回_exprCode。
    结束。
    返回空。
  结束。

  返回空。
结束。

# =============================================================================
# 表达式生成
# =============================================================================

《生成表达式》段(_expr):
  如果_expr等于空那么：
    返回空。
  结束。

  _t等于_expr["_type"]。

  # 数字字面量
  如果_t等于"NumberLiteral"那么：
    返回_expr["value"]之文本。
  结束。

  # 标识符
  如果_t等于"Identifier"那么：
    _name等于_expr["name"]。
    返回"%val = load i32, i32* %"加_name加", align 4\n  %val"。
  结束。

  # 二元运算
  如果_t等于"BinaryOp"那么：
    _leftCode等于《生成表达式》(_expr["left"])。
    _rightCode等于《生成表达式》(_expr["right"])。
    _op等于_expr["op"]。
    
    _llvmOp等于空。
    如果_op等于"加"那么：_llvmOp等于"add"。结束。
    如果_op等于"减"那么：_llvmOp等于"sub"。结束。
    如果_op等于"乘"那么：_llvmOp等于"mul"。结束。
    如果_op等于"除"那么：_llvmOp等于"sdiv"。结束。
    
    如果_llvmOp不等于空那么：
      _reg等于《新寄存器》()。
      返回_leftCode加"\n  "加_rightCode加"\n  "加_reg加" = "加_llvmOp加" i32 "加"%val"加", "加"%val"。
    结束。
    
    # 比较运算
    如果_op等于"大于"那么：
      _llvmOp等于"sgt"。
    结束。
    如果_op等于"小于"那么：
      _llvmOp等于"slt"。
    结束。
    如果_op等于"等于"那么：
      _llvmOp等于"eq"。
    结束。
    
    如果_llvmOp不等于空那么：
      _reg1等于《新寄存器》()。
      _reg2等于《新寄存器》()。
      返回_leftCode加"\n  "加_rightCode加"\n  "加_reg1加" = icmp "加_llvmOp加" i32 "加"%val"加", "加"%val"加"\n  "加_reg2加" = zext i1 "加_reg1加" to i32"。
    结束。
    
    返回空。
  结束。

  # 函数调用
  如果_t等于"FunctionCall"那么：
    如果_expr["name"]["name"]等于"打印"那么：
      _argCode等于《生成表达式》(_expr["arguments"][0])。
      _fmtCode等于"%fmt = getelementptr inbounds [4 x i8], [4 x i8]* @.printf_fmt, i32 0, i32 0"。
      _callCode等于"%ret = call i32 (i8*, ...) @printf(i8* %fmt, i32 "加_argCode加")"。
      返回_fmtCode加"\n  "加_callCode。
    结束。
    
    # 段落调用
    _segName等于_expr["name"]["name"]。
    _reg等于《新寄存器》()。
    返回_reg加" = call i32 @_"加_segName加"(i32 0)"。
  结束。

  # 属性访问（长度）
  如果_t等于"PropertyAccess"那么：
    如果_expr["property"]等于"长度"那么：
      _objCode等于《生成表达式》(_expr["obj"])。
      # 简化：返回常量 0（实际需要运行时支持）
      返回"0"。
    结束。
    返回空。
  结束。

  # 索引访问
  如果_t等于"IndexAccess"那么：
    _objCode等于《生成表达式》(_expr["obj"])。
    _indexCode等于《生成表达式》(_expr["index"])。
    # 简化：返回对象值
    返回_objCode。
  结束。

  # 列表字面量
  如果_t等于"ListLiteral"那么：
    # 简化：返回第一个元素
    如果_expr["elements"]之长度大于0那么：
      返回《生成表达式》(_expr["elements"][0])。
    结束。
    返回"0"。
  结束。

  返回空。
结束。

# =============================================================================
# 入口函数
# =============================================================================

《编译》段(_ast):
  # 主入口：接收 AST 并生成 LLVM IR
  如果 _ast["_type"]等于"Module"那么：
    返回《生成模块》(_ast)。
  结束。
  返回空。
结束。