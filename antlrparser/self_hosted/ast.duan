# 段言自举解析器 - AST 节点定义和构造函数
# 
# 每个 AST 节点是一个字典，包含 "_type" 字段标识节点类型。
# 这些构造函数供解析器使用。

# =============================================================================
# 字面量
# =============================================================================

《创建数字》段(值):
  返回_典("_type", "NumberLiteral", "value", 值)。
结束。

《创建字符串》段(值):
  返回_典("_type", "StringLiteral", "value", 值)。
结束。

《创建布尔》段(值):
  返回_典("_type", "BooleanLiteral", "value", 值)。
结束。

《创建空值》段():
  返回_典("_type", "NullLiteral")。
结束。

# =============================================================================
# 表达式
# =============================================================================

《创建标识》段(名称):
  返回_典("_type", "Identifier", "name", 名称)。
结束。

《创建段名》段(名称):
  返回_典("_type", "SegmentName", "name", 名称)。
结束。

《创建二元运算》段(左, 算符, 右):
  返回_典("_type", "BinaryOp", "left", 左, "op", 算符, "right", 右)。
结束。

《创建一元运算》段(算符, 操作数):
  返回_典("_type", "UnaryOp", "op", 算符, "operand", 操作数)。
结束。

《创建调用》段(名, 参数列):
  返回_典("_type", "FunctionCall", "name", 名, "arguments", 参数列)。
结束。

《创建属性》段(对象, 属性名):
  返回_典("_type", "PropertyAccess", "obj", 对象, "property", 属性名)。
结束。

《创建索引》段(对象, 索引):
  返回_典("_type", "IndexAccess", "obj", 对象, "index", 索引)。
结束。

《创建列表》段(元素列):
  返回_典("_type", "ListLiteral", "elements", 元素列)。
结束。

《创建典条目》段(键, 值):
  返回_典("_type", "DictEntry", "key", 键, "value", 值)。
结束。

《创建典》段(条目列):
  返回_典("_type", "DictLiteral", "entries", 条目列)。
结束。

《创建管道》段(表达式列):
  返回_典("_type", "PipeExpression", "expressions", 表达式列)。
结束。

# =============================================================================
# 语句
# =============================================================================

《创建声明》段(名, 值):
  返回_典("_type", "VariableDeclaration", "name", 名, "value", 值)。
结束。

《创建赋值》段(目标, 值):
  返回_典("_type", "Assignment", "target", 目标, "value", 值)。
结束。

《创建如果》段(条件, 真体, _elif_conds, _elif_bodies, 假体):
  返回_典("_type", "IfStatement", "condition", 条件, "then_body", 真体, "elseif_conditions", _elif_conds, "elseif_bodies", _elif_bodies, "else_body", 假体)。
结束。

《创建遍历》段(变量, _iterable, 体):
  返回_典("_type", "ForeachStatement", "variable", 变量, "iterable", _iterable, "body", 体)。
结束。

《创建当》段(条件, 体):
  返回_典("_type", "WhileStatement", "condition", 条件, "body", 体)。
结束。

《创建跳出》段():
  返回_典("_type", "BreakStatement")。
结束。

《创建跳过》段():
  返回_典("_type", "ContinueStatement")。
结束。

《创建返回》段(值):
  返回_典("_type", "ReturnStatement", "value", 值)。
结束。

《创建尝试》段(试体, _catch_var, _catch_body):
  返回_典("_type", "TryStatement", "try_body", 试体, "catch_var", _catch_var, "catch_body", _catch_body)。
结束。

《创建抛出》段(值):
  返回_典("_type", "ThrowStatement", "value", 值)。
结束。

《创建打印》段(值):
  返回_典("_type", "PrintStatement", "value", 值)。
结束。

《创建表达式》段(表达式):
  返回_典("_type", "ExpressionStatement", "expression", 表达式)。
结束。

# =============================================================================
# 段落定义
# =============================================================================

《创建参数》段(名):
  返回_典("_type", "Parameter", "name", 名)。
结束。

《创建段落》段(名, 参数列, 体):
  返回_典("_type", "SegmentDefinition", "name", 名, "parameters", 参数列, "body", 体)。
结束。

# =============================================================================
# 导入/导出
# =============================================================================

《创建导入》段(_mod_name, 名称列):
  返回_典("_type", "ImportStatement", "module", _mod_name, "names", 名称列)。
结束。

《创建导出》段(名):
  返回_典("_type", "ExportStatement", "name", 名)。
结束。

# =============================================================================
# 模块（顶层容器）
# =============================================================================

《创建模块》段(_segs, _stmts, _imports, _exports):
  返回_典("_type", "Module", "segments", _segs, "statements", _stmts, "imports", _imports, "exports", _exports)。
结束。