# 段言测试程序 - 列表和字典

《主段》段():
  打印("=== 列表测试 ===")。
  
  # 创建列表
  定义arr等于【10, 20, 30, 40, 50】。
  
  # 获取长度
  定义len等于arr之长度。
  打印("列表长度: "加len)。
  
  # 访问元素
  定义first等于arr[0]。
  定义last等于arr[4]。
  打印("第一个元素: "加first)。
  打印("最后一个元素: "加last)。
  
  # 测试列表操作
  定义sum等于0。
  定义i等于0。
  当i小于len：
    sum等于sum加arr[i]。
    i等于i加1。
  结束。
  打印("元素总和: "加sum)。
  
  打印("")。
  打印("=== 字典测试 ===")。
  
  # 创建字典
  定义person等于_典(
    "年龄", 25,
    "成绩", 95,
    "分数", 88
  )。
  
  # 访问字典
  定义age等于person["年龄"]。
  定义score等于person["成绩"]。
  打印("年龄: "加age)。
  打印("成绩: "加score)。
  
  打印("")。
  打印("=== 测试完成 ===")。
结束。